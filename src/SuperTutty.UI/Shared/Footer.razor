@using SuperTutty.UI.Data
@using SuperTutty.UI.Services
@using SuperTutty.Services
@implements IDisposable
@inject IProcessMonitorService ProcessMonitor
@inject NavigationManager NavigationManager
@inject ICommandCatalog CommandCatalog
@inject IJSRuntime JSRuntime
@inject SelectedSessionStore SelectedSessionStore

@* Help Modal *@
@if (_showHelpModal)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm"
        @onclick="CloseHelpModal">
        <div class="bg-[#1a1a1a] border border-[#2b2b2b] rounded-xl shadow-2xl w-[90vw] max-w-4xl max-h-[85vh] flex flex-col"
            @onclick:stopPropagation="true">
            @* Header *@
            <div class="flex items-center justify-between px-5 py-4 border-b border-[#2b2b2b]">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary text-xl">help</span>
                    <h2 class="text-lg font-semibold text-white">명령어 도움말</h2>
                </div>
                <button @onclick="CloseHelpModal"
                    class="p-1.5 rounded-md hover:bg-[#2b2b2b] text-[#858585] hover:text-white transition-colors">
                    <span class="material-symbols-outlined text-lg">close</span>
                </button>
            </div>

            @* Toolbar *@
            <div class="flex items-center gap-4 px-5 py-3 border-b border-[#2b2b2b]">
                <div class="flex items-center gap-2">
                    <button class="@GetHelpPlatformButtonClass(CommandPlatform.Linux)"
                        @onclick="() => _helpSelectedPlatform = CommandPlatform.Linux">
                        <span class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-sm">terminal</span>
                            Linux
                        </span>
                    </button>
                    <button class="@GetHelpPlatformButtonClass(CommandPlatform.Windows)"
                        @onclick="() => _helpSelectedPlatform = CommandPlatform.Windows">
                        <span class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-sm">desktop_windows</span>
                            Windows
                        </span>
                    </button>
                </div>
                <div class="flex-1">
                    <div class="relative">
                        <span
                            class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[#666] text-lg">search</span>
                        <input
                            class="w-full bg-[#121212] border border-[#2b2b2b] rounded-lg pl-10 pr-4 py-2 text-sm text-white placeholder:text-[#666] focus:outline-none focus:border-primary/50"
                            placeholder="명령어 또는 설명 검색..." @bind="_helpSearchText" @bind:event="oninput" />
                    </div>
                </div>
            </div>

            @* Command List *@
            <div class="flex-1 overflow-y-auto p-5">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    @foreach (var preset in FilteredHelpPresets)
                    {
                        <div
                            class="bg-[#121212] border border-[#2b2b2b] rounded-lg p-4 hover:border-[#3b3b3b] transition-colors">
                            <div class="flex items-start justify-between gap-3">
                                <div class="flex-1 min-w-0">
                                    <div class="font-medium text-white text-sm">@preset.Name</div>
                                    <div class="text-xs text-[#999] mt-1">@preset.Description</div>
                                    @if (!string.IsNullOrWhiteSpace(preset.Caution))
                                    {
                                        <div class="flex items-center gap-1 mt-2 text-xs text-amber-400">
                                            <span class="material-symbols-outlined text-sm">warning</span>
                                            @preset.Caution
                                        </div>
                                    }
                                    <div class="mt-3 flex items-center gap-2">
                                        <div class="flex-1 font-mono text-xs bg-[#0a0a0a] text-green-400 px-3 py-2 rounded-md overflow-x-auto cursor-pointer hover:bg-[#151515] transition-colors"
                                            title="클릭하여 복사" @onclick="() => CopyHelpCommand(preset.Command)">
                                            @preset.Command
                                        </div>
                                        <button
                                            class="p-1.5 rounded-md hover:bg-[#2b2b2b] text-[#666] hover:text-white transition-colors shrink-0"
                                            title="클립보드에 복사" @onclick="() => CopyHelpCommand(preset.Command)">
                                            @if (_copiedHelpCommand == preset.Command)
                                            {
                                                <span class="material-symbols-outlined text-green-400 text-base">check</span>
                                            }
                                            else
                                            {
                                                <span class="material-symbols-outlined text-base">content_copy</span>
                                            }
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (!FilteredHelpPresets.Any())
                {
                    <div class="flex flex-col items-center justify-center py-12 text-[#666]">
                        <span class="material-symbols-outlined text-4xl mb-2">search_off</span>
                        <p class="text-sm">검색 결과가 없습니다</p>
                    </div>
                }
            </div>

            @* Footer *@
            <div class="px-5 py-3 border-t border-[#2b2b2b] text-xs text-[#666]">
                총 @FilteredHelpPresets.Count()개의 명령어 | @(_helpSelectedPlatform == CommandPlatform.Linux ? "Linux/Unix 쉘 명령어" : "Windows PowerShell 명령어")
            </div>
        </div>
    </div>
}

@* Settings Modal *@
@if (_showSettingsModal)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm"
        @onclick="CloseSettingsModal">
        <div class="bg-[#1a1a1a] border border-[#2b2b2b] rounded-xl shadow-2xl w-[90vw] max-w-4xl max-h-[85vh] flex flex-col"
            @onclick:stopPropagation="true">

            @* Header *@
            <div class="flex items-center justify-between px-5 py-4 border-b border-[#2b2b2b]">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary text-xl">settings</span>
                    <h2 class="text-lg font-semibold text-white">설정</h2>
                </div>
                <button @onclick="CloseSettingsModal"
                    class="p-1.5 rounded-md hover:bg-[#2b2b2b] text-[#858585] hover:text-white transition-colors">
                    <span class="material-symbols-outlined text-lg">close</span>
                </button>
            </div>

            <div class="flex-1 overflow-y-auto">

                <div class="px-5 py-4 sticky top-0 bg-[#1a1a1a] z-20 border-b border-[#2b2b2b]">
                    <div class="flex h-10 w-full items-center justify-center rounded-lg bg-[#1e1e1e] p-1 shadow-inner">
                        <label @onclick='() => _settingsTab = "App"'
                            class='flex cursor-pointer h-full grow items-center justify-center overflow-hidden rounded-[0.25rem] px-2 @(_settingsTab == "App" ? "bg-[#2D2D2D] shadow-sm text-white" : "text-[#9E9E9E]") text-sm font-medium transition-all'>
                            <span class="truncate">App</span>
                            <input class="invisible w-0 absolute" name="settings_tab" type="radio" value="App" />
                        </label>
                        <label @onclick='() => _settingsTab = "Terminal"'
                            class='flex cursor-pointer h-full grow items-center justify-center overflow-hidden rounded-[0.25rem] px-2 @(_settingsTab == "Terminal" ? "bg-[#2D2D2D] shadow-sm text-white" : "text-[#9E9E9E]") text-sm font-medium transition-all'>
                            <span class="truncate">Terminal</span>
                            <input class="invisible w-0 absolute" name="settings_tab" type="radio" value="Terminal" />
                        </label>
                        <label @onclick='() => _settingsTab = "Task"'
                            class='flex cursor-pointer h-full grow items-center justify-center overflow-hidden rounded-[0.25rem] px-2 @(_settingsTab == "Task" ? "bg-[#2D2D2D] shadow-sm text-white" : "text-[#9E9E9E]") text-sm font-medium transition-all'>
                            <span class="truncate">Task</span>
                            <input class="invisible w-0 absolute" name="settings_tab" type="radio" value="Task" />
                        </label>
                    </div>
                </div>

                @if (_settingsTab == "Terminal")
                {
                    <div class="px-5 mb-6 pt-4">
                        <div
                            class="bg-[#1e1e1e] border border-slate-800 rounded-xl p-4 shadow-xl shadow-black/30 overflow-hidden relative">
                            <div class="absolute top-2 right-2 flex gap-1.5">
                                <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
                                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500"></div>
                                <div class="w-2.5 h-2.5 rounded-full bg-green-500"></div>
                            </div>
                            <div class="font-mono text-sm leading-relaxed text-slate-300 mt-2">
                                <div class="flex gap-2">
                                    <span class="text-green-400 font-bold">user@desktop:~$</span>
                                    <span class="text-white">ls -la</span>
                                </div>
                                <div class="text-slate-400">drwxr-xr-x 5 user staff 160 Jan 12 09:43 .</div>
                                <div class="text-slate-400">drwxr-xr-x 3 user staff 96 Jan 11 14:20 ..</div>
                                <div class="flex gap-2 mt-1">
                                    <span class="text-green-400 font-bold">user@desktop:~$</span>
                                    <span class="text-white">echo "Hello World"</span>
                                </div>
                                <div class="text-white">Hello World</div>
                                <div class="flex gap-2 items-center mt-1">
                                    <span class="text-green-400 font-bold">user@desktop:~$</span>
                                    <span class="w-2 h-4 bg-primary animate-pulse inline-block align-middle"></span>
                                </div>
                            </div>
                            <div
                                class="absolute bottom-2 right-4 text-[10px] uppercase tracking-wider font-bold text-[#9E9E9E] select-none">
                                Preview</div>
                        </div>
                    </div>

                    <div class="px-5 mb-2">
                        <h3 class="text-[#9E9E9E] text-xs font-semibold uppercase tracking-wider mb-2 ml-1">Typography</h3>
                        <div class="bg-[#1e1e1e] rounded-xl overflow-hidden shadow-sm divide-y divide-slate-800">
                            <div
                                class="flex items-center justify-between p-4 active:bg-white/5 cursor-pointer transition-colors">
                                <div class="flex items-center gap-3">
                                    <div class="bg-[#2D2D2D] text-blue-400 rounded-lg p-1.5">
                                        <span class="material-symbols-outlined text-[20px]">text_format</span>
                                    </div>
                                    <span class="text-sm font-medium text-white">Font Family</span>
                                </div>
                                <div class="flex items-center gap-1 text-slate-400">
                                    <span class="text-sm text-slate-300">JetBrains Mono</span>
                                    <span class="material-symbols-outlined text-[20px] text-[#9E9E9E]">chevron_right</span>
                                </div>
                            </div>
                            <div class="flex items-center justify-between p-4">
                                <div class="flex items-center gap-3">
                                    <div class="bg-[#2D2D2D] text-purple-400 rounded-lg p-1.5">
                                        <span class="material-symbols-outlined text-[20px]">format_size</span>
                                    </div>
                                    <span class="text-sm font-medium text-white">Font Size</span>
                                </div>
                                <div class="flex items-center bg-[#121212] rounded-lg p-0.5 border border-slate-700">
                                    <button type="button" @onclick="DecreaseFontSize"
                                        class="w-8 h-8 flex items-center justify-center rounded hover:bg-[#2D2D2D] text-slate-300 transition-colors">
                                        <span class="material-symbols-outlined text-[18px]">remove</span>
                                    </button>
                                    <span
                                        class="w-10 text-center text-sm font-semibold text-white">@_terminalOptions.FontSize</span>
                                    <button type="button" @onclick="IncreaseFontSize"
                                        class="w-8 h-8 flex items-center justify-center rounded hover:bg-[#2D2D2D] text-slate-300 transition-colors">
                                        <span class="material-symbols-outlined text-[18px]">add</span>
                                    </button>
                                </div>
                            </div>
                            <div class="flex flex-col p-4 gap-3">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <div class="bg-[#2D2D2D] text-teal-400 rounded-lg p-1.5">
                                            <span class="material-symbols-outlined text-[20px]">height</span>
                                        </div>
                                        <span class="text-sm font-medium text-white">Line Height</span>
                                    </div>
                                    <span class="text-sm font-semibold text-slate-300">1.5</span>
                                </div>
                                <div class="px-1">
                                    <input class="w-full stty-control stty-range" max="2.5"
                                        min="1" step="0.1" type="range" value="@(_terminalOptions.LineHeight ?? 1.0)"
                                        @oninput="OnLineHeightInput" />
                                </div>
                            </div>

                            <div class="flex flex-col p-4 gap-3">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <div class="bg-[#2D2D2D] text-cyan-300 rounded-lg p-1.5">
                                            <span class="material-symbols-outlined text-[20px]">space_bar</span>
                                        </div>
                                        <div class="flex flex-col">
                                            <span class="text-sm font-medium text-white">Letter Spacing</span>
                                            <span class="text-xs text-slate-400">문자 간격 (xterm option)</span>
                                        </div>
                                    </div>
                                    <span class="text-sm font-semibold text-slate-300">@((_terminalOptions.LetterSpacing ??
                                                                        0).ToString("0.0"))</span>
                                </div>
                                <div class="px-1">
                                    <input class="w-full stty-control stty-range" max="2"
                                        min="0" step="0.1" type="range" value="@(_terminalOptions.LetterSpacing ?? 0)"
                                        @oninput="OnLetterSpacingInput" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="px-5 mt-6 mb-2">
                        <h3 class="text-[#9E9E9E] text-xs font-semibold uppercase tracking-wider mb-2 ml-1">Terminal Visuals
                        </h3>
                        <div class="bg-[#1e1e1e] rounded-xl overflow-hidden shadow-sm divide-y divide-slate-800">
                            <div class="p-4">
                                <div class="flex items-center justify-between mb-3">
                                    <div class="flex items-center gap-3">
                                        <div class="bg-[#2D2D2D] text-orange-400 rounded-lg p-1.5">
                                            <span class="material-symbols-outlined text-[20px]">palette</span>
                                        </div>
                                        <span class="text-sm font-medium text-white">Color Scheme</span>
                                    </div>
                                    <span class="text-sm text-slate-400">Solarized Dark</span>
                                </div>
                                <div class="flex gap-3 overflow-x-auto pb-1 no-scrollbar">
                                    <button type="button"
                                        class="w-10 h-10 rounded-full bg-[#101922] border-2 border-primary ring-2 ring-primary/30 shrink-0"></button>
                                    <button type="button"
                                        class="w-10 h-10 rounded-full bg-[#282a36] border-2 border-transparent hover:border-slate-400 shrink-0"></button>
                                    <button type="button"
                                        class="w-10 h-10 rounded-full bg-[#002b36] border-2 border-transparent hover:border-slate-400 shrink-0"></button>
                                    <button type="button"
                                        class="w-10 h-10 rounded-full bg-[#fafafa] border-2 border-transparent hover:border-slate-400 shrink-0"></button>
                                    <button type="button"
                                        class="w-10 h-10 rounded-full bg-[#585858] border-2 border-transparent hover:border-slate-400 shrink-0"></button>
                                </div>
                            </div>
                            <div class="p-4">
                                <div class="flex items-center justify-between mb-3">
                                    <div class="flex items-center gap-3">
                                        <div class="bg-[#2D2D2D] text-indigo-400 rounded-lg p-1.5">
                                            <span class="material-symbols-outlined text-[20px]">input</span>
                                        </div>
                                        <span class="text-sm font-medium text-white">Cursor Style</span>
                                    </div>
                                </div>
                                <div class="grid grid-cols-3 gap-2">
                                    <button type="button" @onclick='() => SetCursorStyle("block")'
                                        class='flex flex-col items-center justify-center p-2 rounded-lg bg-[#121212] border-2 @GetCursorStyleClass("block")'>
                                        <div class="w-4 h-6 bg-current mb-1"></div>
                                        <span class="text-[10px] font-bold">Block</span>
                                    </button>
                                    <button type="button" @onclick='() => SetCursorStyle("underline")'
                                        class='flex flex-col items-center justify-center p-2 rounded-lg bg-[#121212] border-2 @GetCursorStyleClass("underline")'>
                                        <div class="w-4 h-6 border-b-2 border-current mb-1"></div>
                                        <span class="text-[10px] font-medium">Underline</span>
                                    </button>
                                    <button type="button" @onclick='() => SetCursorStyle("bar")'
                                        class='flex flex-col items-center justify-center p-2 rounded-lg bg-[#121212] border-2 @GetCursorStyleClass("bar")'>
                                        <div class="w-0.5 h-6 bg-current mb-1"></div>
                                        <span class="text-[10px] font-medium">Bar</span>
                                    </button>
                                </div>
                            </div>
                            <div class="flex items-center justify-between p-4">
                                <div class="flex items-center gap-3">
                                    <div class="bg-[#2D2D2D] text-pink-400 rounded-lg p-1.5">
                                        <span class="material-symbols-outlined text-[20px]">flourescent</span>
                                    </div>
                                    <span class="text-sm font-medium text-white">Blink Cursor</span>
                                </div>
                                <div
                                    class="relative inline-block w-12 mr-2 align-middle select-none transition duration-200 ease-in">
                                    <input
                                        class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer transition-all duration-300 ease-in-out border-slate-700 checked:bg-primary checked:border-primary"
                                        id="blink-toggle" name="toggle" type="checkbox" checked="@_terminalOptions.CursorBlink"
                                        @onchange="OnCursorBlinkChanged" />
                                    <label
                                        class="toggle-label block overflow-hidden h-6 rounded-full bg-slate-700 cursor-pointer transition-colors duration-300 ease-in-out checked:bg-primary"
                                        for="blink-toggle"></label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="px-5 mt-6 mb-2">
                        <h3 class="text-[#9E9E9E] text-xs font-semibold uppercase tracking-wider mb-2 ml-1">Buffer &amp; History
                        </h3>
                        <div class="bg-[#1e1e1e] rounded-xl overflow-hidden shadow-sm divide-y divide-slate-800">
                            <div class="flex items-center justify-between p-4">
                                <div class="flex items-center gap-3">
                                    <div class="bg-[#2D2D2D] text-emerald-400 rounded-lg p-1.5">
                                        <span class="material-symbols-outlined text-[20px]">history</span>
                                    </div>
                                    <span class="text-sm font-medium text-white">Scrollback Lines</span>
                                </div>
                                <div class="relative">
                                    <input
                                        class="w-20 bg-[#121212] border border-slate-700 rounded-lg py-1.5 px-2 text-right text-sm font-semibold text-white focus:ring-2 focus:ring-primary outline-none"
                                        type="number" value="@_terminalOptions.Scrollback" @oninput="OnScrollbackInput" />
                                </div>
                            </div>
                            <div class="flex items-center justify-between p-4">
                                <div class="flex items-center gap-3">
                                    <div class="bg-[#2D2D2D] text-cyan-400 rounded-lg p-1.5">
                                        <span class="material-symbols-outlined text-[20px]">vertical_align_bottom</span>
                                    </div>
                                    <span class="text-sm font-medium text-white">Scroll on Output</span>
                                </div>
                                <div
                                    class="relative inline-block w-12 mr-2 align-middle select-none transition duration-200 ease-in">
                                    <input checked="@_terminalAutoScroll"
                                        class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer transition-all duration-300 ease-in-out border-slate-700 checked:bg-primary checked:border-primary"
                                        id="scroll-toggle" name="toggle" type="checkbox" @onchange="OnAutoScrollChanged" />
                                    <label
                                        class="toggle-label block overflow-hidden h-6 rounded-full bg-slate-700 cursor-pointer transition-colors duration-300 ease-in-out checked:bg-primary"
                                        for="scroll-toggle"></label>
                                </div>
                            </div>

                            <div class="flex items-center justify-between p-4">
                                <div class="flex items-center gap-3">
                                    <div class="bg-[#2D2D2D] text-sky-300 rounded-lg p-1.5">
                                        <span class="material-symbols-outlined text-[20px]">font_download</span>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-sm font-medium text-white">Font Family</span>
                                        <span class="text-xs text-slate-400">빈 값이면 기본 모노스페이스</span>
                                    </div>
                                </div>
                                <input type="text" value="@(_terminalOptions.FontFamily ?? string.Empty)"
                                    placeholder="e.g. JetBrains Mono"
                                    class="w-64 stty-control"
                                    @oninput="OnFontFamilyInput" />
                            </div>

                            <div class="flex items-center justify-between p-4">
                                <div class="flex items-center gap-3">
                                    <div class="bg-[#2D2D2D] text-fuchsia-300 rounded-lg p-1.5">
                                        <span class="material-symbols-outlined text-[20px]">opacity</span>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-sm font-medium text-white">Allow Transparency</span>
                                        <span class="text-xs text-slate-400">배경 투명 허용</span>
                                    </div>
                                </div>
                                <div
                                    class="relative inline-block w-12 mr-2 align-middle select-none transition duration-200 ease-in">
                                    <input checked="@_terminalOptions.AllowTransparency"
                                        class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer transition-all duration-300 ease-in-out border-slate-700 checked:bg-primary checked:border-primary"
                                        id="allow-transparency-toggle" name="toggle" type="checkbox"
                                        @onchange="OnAllowTransparencyChanged" />
                                    <label
                                        class="toggle-label block overflow-hidden h-6 rounded-full bg-slate-700 cursor-pointer transition-colors duration-300 ease-in-out checked:bg-primary"
                                        for="allow-transparency-toggle"></label>
                                </div>
                            </div>

                            <div class="flex items-center justify-between p-4">
                                <div class="flex items-center gap-3">
                                    <div class="bg-[#2D2D2D] text-amber-300 rounded-lg p-1.5">
                                        <span class="material-symbols-outlined text-[20px]">contrast</span>
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-sm font-medium text-white">Bright Bold Colors</span>
                                        <span class="text-xs text-slate-400">굵은 글씨를 밝은 색으로 표시</span>
                                    </div>
                                </div>
                                <div
                                    class="relative inline-block w-12 mr-2 align-middle select-none transition duration-200 ease-in">
                                    <input checked="@_terminalOptions.DrawBoldTextInBrightColors"
                                        class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer transition-all duration-300 ease-in-out border-slate-700 checked:bg-primary checked:border-primary"
                                        id="bright-bold-toggle" name="toggle" type="checkbox"
                                        @onchange="OnDrawBoldTextInBrightColorsChanged" />
                                    <label
                                        class="toggle-label block overflow-hidden h-6 rounded-full bg-slate-700 cursor-pointer transition-colors duration-300 ease-in-out checked:bg-primary"
                                        for="bright-bold-toggle"></label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="px-5 mt-6 mb-2">
                        <h3 class="text-[#9E9E9E] text-xs font-semibold uppercase tracking-wider mb-2 ml-1">Clipboard &amp;
                            Input
                        </h3>
                        <div class="bg-[#1e1e1e] rounded-xl overflow-hidden shadow-sm divide-y divide-slate-800">
                            <div class="flex items-center justify-between p-4">
