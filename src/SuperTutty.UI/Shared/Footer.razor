@code {
    [CascadingParameter] LayoutChrome Layout { get; set; }

    [Parameter]
    public RenderFragment? Content { get; set; }

    private ProcessMetrics _metrics = new();
    private string _currentTab = "terminal";
    private int? _currentSessionId;

    protected override void OnInitialized()
    {
        ProcessMonitor.MetricsUpdated += OnMetricsUpdated;
        ProcessMonitor.Start(TimeSpan.FromSeconds(2));
        NavigationManager.LocationChanged += OnLocationChanged;
        UpdateCurrentTabFromUrl();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateCurrentTabFromUrl();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateCurrentTabFromUrl()
    {
        var uri = new Uri(NavigationManager.Uri);
        var path = uri.AbsolutePath;

        // Parse /session/{id}/{tab} pattern
        var segments = path.Split('/', StringSplitOptions.RemoveEmptyEntries);
        if (segments.Length >= 2 && segments[0] == "session" && int.TryParse(segments[1], out var sessionId))
        {
            _currentSessionId = sessionId;
            _currentTab = segments.Length >= 3 ? segments[2].ToLower() : "terminal";
        }
    }

    private void NavigateToTab(string tab)
    {
        if (_currentSessionId.HasValue)
        {
            NavigationManager.NavigateTo($"/session/{_currentSessionId.Value}/{tab}");
        }
    }

    private string GetTabClass(string tab)
    {
        if (_currentTab == tab)
        {
            return "bg-[#1e1e1e] text-[#e0e0e0] hover:bg-[#262626]";
        }
        return "text-[#666] hover:text-[#e0e0e0] hover:bg-[#1e1e1e]";
    }

    private void OnMetricsUpdated(object? sender, ProcessMetrics metrics)
    {
        _metrics = metrics;
        InvokeAsync(StateHasChanged);
    }

    private string GetCpuColorClass()
    {
        return _metrics.CpuUsagePercent switch
        {
            > 80 => "text-red-400 hover:text-red-300",
            > 50 => "text-amber-400 hover:text-amber-300",
            > 20 => "text-yellow-400 hover:text-yellow-300",
            _ => "hover:text-[#999]"
        };
    }

    // Help Modal
    private bool _showHelpModal = false;
    private bool _showSettingsModal = false;

    private string _settingsTab = "Terminal";

    private TerminalOptions _terminalOptions = TerminalPreferences.LoadOptions();
    private bool _terminalAutoScroll = true;
    private CommandPlatform _helpSelectedPlatform = CommandPlatform.Linux;
    private string _helpSearchText = string.Empty;
    private string? _copiedHelpCommand = null;
    private System.Threading.Timer? _helpCopyResetTimer;

    private void OpenSettingsModal()
    {
        _showSettingsModal = true;
    }

    private void CloseSettingsModal()
    {
        _showSettingsModal = false;
    }

    private async Task ApplyTerminalOptionsLiveAsync()
    {
        TerminalPreferences.SaveOptions(_terminalOptions);

        try
        {
            // Apply to any active terminals. SessionTerminal should subscribe for single-target apply; this is a best-effort
            await JSRuntime.InvokeVoidAsync("terminal.applyGlobalOptions", _terminalOptions.ToJsOptions(), _terminalAutoScroll);
        }
        catch
        {
            // ignore if terminal page isn't loaded
        }
    }

    private void IncreaseFontSize()
    {
        _terminalOptions.FontSize = Math.Clamp(_terminalOptions.FontSize + 1, 8, 36);
        _ = ApplyTerminalOptionsLiveAsync();
    }

    private void DecreaseFontSize()
    {
        _terminalOptions.FontSize = Math.Clamp(_terminalOptions.FontSize - 1, 8, 36);
        _ = ApplyTerminalOptionsLiveAsync();
    }

    private void SetCursorStyle(string style)
    {
        _terminalOptions.CursorStyle = style;
        _ = ApplyTerminalOptionsLiveAsync();
    }

    private string GetCursorStyleClass(string style)
    {
        var isActive = string.Equals(_terminalOptions.CursorStyle, style, StringComparison.OrdinalIgnoreCase);
        return isActive ? "border-primary text-primary" : "border-slate-700 text-slate-400 hover:bg-[#2D2D2D]";
    }

    private void OnCursorBlinkChanged(ChangeEventArgs e)
    {
        if (e?.Value is bool b)
        {
            _terminalOptions.CursorBlink = b;
        }
        else
        {
            _terminalOptions.CursorBlink = !_terminalOptions.CursorBlink;
        }
        _ = ApplyTerminalOptionsLiveAsync();
    }

    private void OnScrollbackInput(ChangeEventArgs e)
    {
        if (int.TryParse(e?.Value?.ToString(), out var n))
        {
            _terminalOptions.Scrollback = Math.Clamp(n, 100, 200000);
            _ = ApplyTerminalOptionsLiveAsync();
        }
    }

    private void OnLineHeightInput(ChangeEventArgs e)
    {
        if (double.TryParse(e?.Value?.ToString(), out var d))
        {
            _terminalOptions.LineHeight = Math.Clamp(d, 1.0, 2.5);
            _ = ApplyTerminalOptionsLiveAsync();
        }
    }

    private void OnLetterSpacingInput(ChangeEventArgs e)
    {
        if (double.TryParse(e?.Value?.ToString(), out var d))
        {
            _terminalOptions.LetterSpacing = Math.Clamp(d, 0.0, 2.0);
            _ = ApplyTerminalOptionsLiveAsync();
        }
    }

    private void OnFontFamilyInput(ChangeEventArgs e)
    {
        var text = e?.Value?.ToString() ?? string.Empty;
        text = text.Trim();
        _terminalOptions.FontFamily = string.IsNullOrEmpty(text) ? null : text;
        _ = ApplyTerminalOptionsLiveAsync();
    }

    private void OnAllowTransparencyChanged(ChangeEventArgs e)
    {
        if (e?.Value is bool b)
        {
            _terminalOptions.AllowTransparency = b;
        }
        else
        {
            _terminalOptions.AllowTransparency = !_terminalOptions.AllowTransparency;
        }

        _ = ApplyTerminalOptionsLiveAsync();
    }

    private void OnDrawBoldTextInBrightColorsChanged(ChangeEventArgs e)
    {
        if (e?.Value is bool b)
        {
            _terminalOptions.DrawBoldTextInBrightColors = b;
        }
        else
        {
            _terminalOptions.DrawBoldTextInBrightColors = !_terminalOptions.DrawBoldTextInBrightColors;
        }

        _ = ApplyTerminalOptionsLiveAsync();
    }

    private async Task OnAutoScrollChanged(ChangeEventArgs e)
    {
        if (e?.Value is bool b)
        {
            _terminalAutoScroll = b;
        }
        else
        {
            _terminalAutoScroll = !_terminalAutoScroll;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("terminal.applyGlobalOptions", _terminalOptions.ToJsOptions(), _terminalAutoScroll);
        }
        catch
        {
        }
    }

    private void OnCopyOnSelectChanged(ChangeEventArgs e)
    {
        if (e?.Value is bool b)
        {
            _terminalOptions.CopyOnSelect = b;
        }
        else
        {
            _terminalOptions.CopyOnSelect = !_terminalOptions.CopyOnSelect;
        }

        _ = ApplyTerminalOptionsLiveAsync();
    }

    private void OnRightClickPasteChanged(ChangeEventArgs e)
    {
        if (e?.Value is bool b)
        {
            _terminalOptions.RightClickPaste = b;
        }
        else
        {
            _terminalOptions.RightClickPaste = !_terminalOptions.RightClickPaste;
        }

        _ = ApplyTerminalOptionsLiveAsync();
    }

    private void OnRightClickSelectChanged(ChangeEventArgs e)
    {
        if (e?.Value is bool b)
        {
            _terminalOptions.RightClickSelectsWord = b;
        }
        else
        {
            _terminalOptions.RightClickSelectsWord = !_terminalOptions.RightClickSelectsWord;
        }

        _ = ApplyTerminalOptionsLiveAsync();
    }

    private void OnBracketedPasteChanged(ChangeEventArgs e)
    {
        if (e?.Value is bool b)
        {
            _terminalOptions.BracketedPasteMode = b;
        }
        else
        {
            _terminalOptions.BracketedPasteMode = !_terminalOptions.BracketedPasteMode;
        }

        _ = ApplyTerminalOptionsLiveAsync();
    }

    private void OnHistoryEnabledChanged(ChangeEventArgs e)
    {
        if (e?.Value is bool b)
        {
            _terminalOptions.HistoryEnabled = b;
        }
        else
        {
            _terminalOptions.HistoryEnabled = !_terminalOptions.HistoryEnabled;
        }

        _ = ApplyTerminalOptionsLiveAsync();
    }

    private void OnPersistHistoryChanged(ChangeEventArgs e)
    {
        if (e?.Value is bool b)
        {
            _terminalOptions.PersistHistory = b;
        }
        else
        {
            _terminalOptions.PersistHistory = !_terminalOptions.PersistHistory;
        }

        _ = ApplyTerminalOptionsLiveAsync();
    }

    private void OnHistoryLimitChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e?.Value?.ToString(), out var limit))
        {
            _terminalOptions.HistoryLimit = Math.Clamp(limit, 10, 5000);
            _ = ApplyTerminalOptionsLiveAsync();
        }
    }

    private void OpenHelpModal()
    {
        _showHelpModal = true;
        _helpSearchText = string.Empty;
        _copiedHelpCommand = null;
    }

    private void CloseHelpModal()
    {
        _showHelpModal = false;
        _copiedHelpCommand = null;
    }

    private async Task CopyHelpCommand(string command)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", command);
            _copiedHelpCommand = command;
            StateHasChanged();

            // 2초 후 체크 아이콘을 다시 복사 아이콘으로 변경
            _helpCopyResetTimer?.Dispose();
            _helpCopyResetTimer = new System.Threading.Timer(_ =>
            {
                _copiedHelpCommand = null;
                InvokeAsync(StateHasChanged);
            }, null, 2000, System.Threading.Timeout.Infinite);
        }
        catch
        {
            // 클립보드 접근 실패 시 무시
        }
    }

    private IEnumerable<CommandPreset> FilteredHelpPresets => CommandCatalog
    .GetByPlatform(_helpSelectedPlatform)
    .Where(preset => MatchesHelpSearch(preset));

    private bool MatchesHelpSearch(CommandPreset preset)
    {
        if (string.IsNullOrWhiteSpace(_helpSearchText))
        {
            return true;
        }
        var term = _helpSearchText.Trim();
        return preset.Name.Contains(term, StringComparison.OrdinalIgnoreCase)
        || preset.Description.Contains(term, StringComparison.OrdinalIgnoreCase)
        || preset.Command.Contains(term, StringComparison.OrdinalIgnoreCase);
    }

    private string GetHelpPlatformButtonClass(CommandPlatform platform)
    {
        var isActive = platform == _helpSelectedPlatform;
        return isActive
        ? "px-3 py-1.5 text-xs font-medium bg-primary text-white rounded-md"
        : "px-3 py-1.5 text-xs font-medium bg-[#2b2b2b] text-[#999] hover:text-white hover:bg-[#3b3b3b] rounded-md transition-colors";
    }

    private SessionPlatform? CurrentSessionPlatform => SelectedSessionStore.Current?.Platform;

    private string GetModeSwitchItemClass(SessionPlatform platform)
    {
        var isActive = CurrentSessionPlatform == platform;
        return isActive
        ? "bg-[#3b82f6] text-white font-medium shadow-sm"
        : "hover:bg-[#1e1e1e] text-[#666] hover:text-[#999]";
    }

    public void Dispose()
    {
        ProcessMonitor.MetricsUpdated -= OnMetricsUpdated;
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}