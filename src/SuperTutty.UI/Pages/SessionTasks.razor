    private void RegisterLogStreamHandlers()
    {
        LogStreamService.LiveLogReceived += OnLogStreamReceived;
        LogStreamService.StreamError += OnLogStreamError;
    }

    private void UnregisterLogStreamHandlers()
    {
        LogStreamService.LiveLogReceived -= OnLogStreamReceived;
        LogStreamService.StreamError -= OnLogStreamError;
    }

    private void OnLogStreamReceived(object? sender, string logLine)
    {
        if (string.IsNullOrWhiteSpace(logLine)) return;
        _ = AppendLogLineAsync(logLine);
    }

    private async Task AppendLogLineAsync(string logLine)
    {
        await InvokeAsync(async () =>
        {
            LogEntries.Add(ParseLogLine(logLine));
            if (LogEntries.Count > MaxLogEntries)
            {
                LogEntries.RemoveAt(0);
            }
            StateHasChanged();
            await Task.Yield();
            await ScrollLogMessagesToBottom();
        });
    }

    private async Task ScrollLogMessagesToBottom()
    {
        if (!string.IsNullOrEmpty(LogEntriesContainerRef.Id))
        {
            await JSRuntime.InvokeVoidAsync("scrollToBottom", LogEntriesContainerRef);
        }
    }

    private void OnLogStreamError(object? sender, Exception exception)
    {
        LogStreamErrorMessage = exception.Message;
        _ = InvokeAsync(StateHasChanged);
    }

    private LogEntry ParseLogLine(string rawLine)
    {
        var sanitized = rawLine.TrimEnd('\r', '\n');
        var match = LogLineRegex.Match(sanitized);
        if (match.Success)
        {
            return new LogEntry(match.Groups["timestamp"].Value, match.Groups["level"].Value, match.Groups["message"].Value);
        }
        return new LogEntry(string.Empty, "INFO", sanitized);
    }

