    // Task Panel Methods
    private void ToggleTaskPanel()
    {
        if (!_isDragging)
        {
            IsTaskPanelMinimized = !IsTaskPanelMinimized;
        }
    }

    private void OnTouchStart(TouchEventArgs e)
    {
        if (e.Touches.Length > 0)
        {
            _touchStartY = e.Touches[0].ClientY;
            _touchCurrentY = _touchStartY;
            _isDragging = false;
        }
    }

    private void OnTouchMove(TouchEventArgs e)
    {
        if (e.Touches.Length > 0)
        {
            _touchCurrentY = e.Touches[0].ClientY;
            var delta = _touchCurrentY - _touchStartY;
            if (Math.Abs(delta) > 10)
            {
                _isDragging = true;
            }
        }
    }

    private void OnTouchEnd(TouchEventArgs e)
    {
        var delta = _touchCurrentY - _touchStartY;
        const double threshold = 50;

        if (_isDragging)
        {
            if (delta > threshold)
            {
                IsTaskPanelMinimized = true;
            }
            else if (delta < -threshold)
            {
                IsTaskPanelMinimized = false;
            }
        }
        _isDragging = false;
    }
    
    // Add Task Modal Methods
    private void OpenAddTaskModal()
    {
        _showAddTaskModal = true;
        _editingTaskId = null;
        _newTaskName = string.Empty;
        _newTaskLogPath = "/var/log/syslog";
        _autoStartTask = true;
        _addTaskError = null;
        
        // Reset analyzer options to defaults
        _useDrainParser = true;
        _useTransactionAnalyzer = true;
        _useEquipmentAnalyzer = true;
        _persistLogs = true;

        _filterKind = LogStreamFilterKind.FixedString;
        _filterIncludePatterns.Clear();
        _filterIncludePatterns.Add(string.Empty);
        _filterExcludePatterns.Clear();
        _filterExcludePatterns.Add(string.Empty);
        _filterIgnoreCase = true;
        _filterInvertMatch = false;
        
        // Expand panel when adding task
        IsTaskPanelMinimized = false;
    }
    
    private void CloseAddTaskModal()
    {
        _showAddTaskModal = false;
        _addTaskError = null;
        _editingTaskId = null;
    }

    private async Task OpenEditTaskModalAsync(Guid taskId)
    {
        _addTaskError = null;

        var task = TaskManager.GetTask(taskId);
        if (task == null)
        {
            return;
        }

        if (task.Status == StreamTaskStatus.Running || task.Status == StreamTaskStatus.Connecting)
        {
            _addTaskError = "Stop the task before editing";
            return;
        }

        _editingTaskId = taskId;
        _showAddTaskModal = true;

        _newTaskName = task.Name;
        _newTaskLogPath = task.LogFilePath;

        _useDrainParser = task.AnalyzerOptions.UseDrainLogParser;
        _useTransactionAnalyzer = task.AnalyzerOptions.UseTransactionAnalyzer;
        _useEquipmentAnalyzer = task.AnalyzerOptions.UseEquipmentAnalyzer;
        _persistLogs = task.AnalyzerOptions.PersistLogs;

        _filterKind = task.FilterOptions?.Kind ?? LogStreamFilterKind.FixedString;
        _filterIgnoreCase = task.FilterOptions?.IgnoreCase ?? true;
        _filterInvertMatch = task.FilterOptions?.InvertMatch ?? false;

        _filterIncludePatterns.Clear();
        foreach (var p in LogStreamFilterPatternParser.Split(task.FilterOptions?.Include))
        {
            _filterIncludePatterns.Add(p);
        }
        if (_filterIncludePatterns.Count == 0)
        {
            _filterIncludePatterns.Add(string.Empty);
        }

        _filterExcludePatterns.Clear();
        foreach (var p in LogStreamFilterPatternParser.Split(task.FilterOptions?.Exclude))
        {
            _filterExcludePatterns.Add(p);
        }
        if (_filterExcludePatterns.Count == 0)
        {
            _filterExcludePatterns.Add(string.Empty);
        }

        // Try to load persisted settings (AutoStart, etc.)
        if (CurrentSession != null)
        {
            var sessionsWithTasks = await SessionStorage.LoadWithTasksAsync();
            var sessionWithTasks = sessionsWithTasks.FirstOrDefault(s =>
                s.Host == CurrentSession.Host &&
                s.Port == CurrentSession.Port &&
                s.Username == CurrentSession.Username);

            var saved = sessionWithTasks?.Tasks.FirstOrDefault(t => string.Equals(t.Id, taskId.ToString(), StringComparison.OrdinalIgnoreCase));
            if (saved != null)
            {
                _autoStartTask = saved.AutoStart;
            }
            else
            {
                _autoStartTask = false;
            }
        }
        else
        {
            _autoStartTask = false;
        }

        IsTaskPanelMinimized = false;
    }

    private async Task SaveTaskAsync()
    {
        _addTaskError = null;
        
        // Validation
        if (string.IsNullOrWhiteSpace(_newTaskLogPath))
        {
            _addTaskError = "Log file path is required";
            return;
        }
        
        if (CurrentSession == null)
        {
            _addTaskError = "No session available";
            return;
        }
        
        try
        {
            var taskName = string.IsNullOrWhiteSpace(_newTaskName) 
                ? $"{CurrentSession.Name} - {System.IO.Path.GetFileName(_newTaskLogPath)}"
                : _newTaskName;
            
            // Create analyzer options based on user selection
            var analyzerOptions = new TaskAnalyzerOptions
            {
                UseDrainLogParser = _useDrainParser,
                UseTransactionAnalyzer = _useTransactionAnalyzer,
                UseEquipmentAnalyzer = _useEquipmentAnalyzer,
                PersistLogs = _persistLogs
            };

            LogStreamFilterOptions? filterOptions = null;
            var includeList = NormalizePatterns(_filterIncludePatterns);
            var excludeList = NormalizePatterns(_filterExcludePatterns);
            var include = string.Join("\n", includeList);
            var exclude = string.Join("\n", excludeList);
            if (include.Length > 0 || exclude.Length > 0)
            {
                if (_filterKind == LogStreamFilterKind.Regex)
                {
                    // Validate patterns early to surface a friendly error in the modal.
                    var regexOptions = RegexOptions.CultureInvariant;
                    if (_filterIgnoreCase)
                    {
                        regexOptions |= RegexOptions.IgnoreCase;
                    }

                    foreach (var pattern in includeList)
                    {
                        _ = new Regex(pattern, regexOptions, matchTimeout: TimeSpan.FromMilliseconds(100));
                    }

                    foreach (var pattern in excludeList)
                    {
                        _ = new Regex(pattern, regexOptions, matchTimeout: TimeSpan.FromMilliseconds(100));
                    }
                }

                filterOptions = new LogStreamFilterOptions
                {
                    Include = include.Length == 0 ? null : include,
                    Exclude = exclude.Length == 0 ? null : exclude,
                    Kind = _filterKind,
                    IgnoreCase = _filterIgnoreCase,
                    InvertMatch = _filterInvertMatch
                };
            }

            var task = TaskFactory.CreateTask(CurrentSession, _newTaskLogPath, taskName, analyzerOptions, filterOptions);

            // If editing, remove the old task + persisted entry first.
            if (_editingTaskId.HasValue)
            {
                var oldTask = TaskManager.GetTask(_editingTaskId.Value);
                if (oldTask == null)
                {
                    _addTaskError = "Task no longer exists";
                    return;
                }

                if (oldTask.Status == StreamTaskStatus.Running || oldTask.Status == StreamTaskStatus.Connecting)
                {
                    _addTaskError = "Stop the task before editing";
                    return;
                }

                await SessionStorage.RemoveTaskFromSessionAsync(CurrentSession, _editingTaskId.Value.ToString());
                await TaskManager.RemoveTaskAsync(_editingTaskId.Value);
            }

            TaskManager.AddTask(task);
            
            // Save task to storage for persistence
            var savedTaskInfo = new SavedTaskInfo
            {
                Id = task.Id.ToString(),
                Name = taskName,
                LogFilePath = _newTaskLogPath,
                CreatedAt = task.CreatedAt,
                UseDrainLogParser = _useDrainParser,
                UseTransactionAnalyzer = _useTransactionAnalyzer,
                UseEquipmentAnalyzer = _useEquipmentAnalyzer,
                PersistLogs = _persistLogs,
                AutoStart = _autoStartTask,
                FilterInclude = filterOptions?.Include,
                FilterExclude = filterOptions?.Exclude,
                FilterKind = filterOptions?.Kind ?? LogStreamFilterKind.FixedString,
                FilterIgnoreCase = filterOptions?.IgnoreCase ?? true,
                FilterInvertMatch = filterOptions?.InvertMatch ?? false
            };
            await SessionStorage.AddTaskToSessionAsync(CurrentSession, savedTaskInfo);
            
            if (_autoStartTask)
            {
                await task.StartAsync();
            }
            
            CloseAddTaskModal();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _addTaskError = ex.Message;
        }
    }
    
    private async Task StartTaskAsync(Guid taskId)
    {
        await TaskManager.StartTaskAsync(taskId);
        StateHasChanged();
    }
    
    private async Task StopTaskAsync(Guid taskId)
    {
        await TaskManager.StopTaskAsync(taskId);
        StateHasChanged();
    }
    
    private async Task RemoveTaskAsync(Guid taskId)
    {
        // Remove from storage first
        if (CurrentSession != null)
        {
            await SessionStorage.RemoveTaskFromSessionAsync(CurrentSession, taskId.ToString());
        }
        
        await TaskManager.RemoveTaskAsync(taskId);
        StateHasChanged();
    }
    
