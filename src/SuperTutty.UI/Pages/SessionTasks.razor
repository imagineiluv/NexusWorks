@page "/session/{SessionId:int}/task"
@implements IAsyncDisposable
@using System.Text.RegularExpressions
@using Microsoft.Extensions.Options
@using SuperTutty.Services
@using SuperTutty.Services.Tasks
@using SuperTutty.UI.Data
@inject NavigationManager NavigationManager
@inject SessionManager SessionManager
@inject SelectedSessionStore SelectedSessionStore
@inject IJSRuntime JSRuntime
@inject ILogStreamService LogStreamService
@inject IOptions<LogStreamOptions> LogStreamOptions
@inject ITaskManager TaskManager
@inject IStreamTaskFactory TaskFactory
@inject ISessionStorage SessionStorage

<div class="relative flex flex-1 flex-col overflow-hidden">

    @* Logs Content *@
    <div class="flex-grow overflow-hidden">
        <div class="px-4 py-3">
            <label class="flex h-12 w-full min-w-40 flex-col">
                <div class="flex h-full w-full flex-1 items-stretch rounded-lg">
                    <div class="flex items-center justify-center rounded-l-lg border-r-0 border-[#1e1e1e] bg-[#1e1e1e] pl-4 text-[#9E9E9E]">
                        <span class="material-symbols-outlined text-2xl">search</span>
                    </div>
                    <input @bind="LogSearchTerm" @bind:event="oninput"
                        class="form-input h-full min-w-0 flex-1 resize-none overflow-hidden rounded-r-lg border-none bg-[#1e1e1e] px-4 pl-2 text-base font-normal leading-normal text-white placeholder:text-[#9E9E9E] focus:outline-0 focus:ring-0"
                        placeholder="Search logs by keywords" />
                </div>
            </label>
        </div>

        <div class="flex gap-3 overflow-x-auto p-3 pt-0">
            <button class="@GetFilterClass("All")" @onclick='() => SetLogFilter("All")'>
                <p class="text-white text-sm font-medium leading-normal">All</p>
            </button>
            <button class="@GetFilterClass("Info")" @onclick='() => SetLogFilter("Info")'>
                <p class="text-white text-sm font-medium leading-normal">Info</p>
            </button>
            <button class="@GetFilterClass("Warn")" @onclick='() => SetLogFilter("Warn")'>
                <p class="text-white text-sm font-medium leading-normal">Warn</p>
            </button>
            <button class="@GetFilterClass("Error")" @onclick='() => SetLogFilter("Error")'>
                <p class="text-white text-sm font-medium leading-normal">Error</p>
            </button>
            <button class="@GetFilterClass("Critical")" @onclick='() => SetLogFilter("Critical")'>
                <p class="text-white text-sm font-medium leading-normal">Critical</p>
            </button>
        </div>

        <div class="flex flex-col gap-1 px-4 pb-4 overflow-y-auto" style="max-height: calc(100vh - 280px);" @ref="LogEntriesContainerRef">
            @foreach (var entry in FilteredLogEntries)
            {
                <div class="flex items-center gap-4 min-h-[72px] rounded-lg bg-[#1e1e1e]/50 p-3 hover:bg-[#262626] transition-colors">
                    <div class="flex size-10 shrink-0 items-center justify-center rounded-full @GetLevelBgClass(entry.Level)">
                        <span class="material-symbols-outlined @GetLevelTextClass(entry.Level) text-xl">@GetLevelIcon(entry.Level)</span>
                    </div>
                    <div class="flex flex-1 flex-col justify-center">
                        <p class="text-base font-medium leading-normal text-white">[@entry.Level.ToUpper()] @entry.Message</p>
                        @if (!string.IsNullOrEmpty(entry.Timestamp))
                        {
                            <p class="text-sm font-normal leading-normal text-[#9E9E9E]">@entry.Timestamp</p>
                        }
                    </div>
                </div>
            }

            @if (!FilteredLogEntries.Any())
            {
                <div class="flex flex-col items-center justify-center py-12 text-[#9E9E9E]">
                    <span class="material-symbols-outlined text-4xl mb-2">description</span>
                    <p class="text-sm">No log entries found</p>
                </div>
            }
        </div>

        @* Bottom Sheet Tasks Panel - positioned above footer (h-10 + h-7 = 68px) *@
        <div class="fixed left-0 right-0 z-50" style="bottom: 68px;">
            <div class="w-full rounded-t-xl bg-[#1d2833] shadow-lg transition-all duration-300 ease-out overflow-hidden"
                 style="max-height: @(IsTaskPanelMinimized ? "40px" : "50vh");">
                @* Drag Handle & Header *@
                <div class="flex items-center justify-between px-3 cursor-pointer select-none transition-all duration-200 @(IsTaskPanelMinimized ? "py-2.5" : "py-3 px-4")"
                     @onclick="ToggleTaskPanel"
                     @ontouchstart="OnTouchStart"
                     @ontouchmove="OnTouchMove"
                     @ontouchend="OnTouchEnd">
                    <div class="flex items-center gap-2">
                        <div class="h-1 w-6 rounded-full bg-gray-600 transition-all duration-200"></div>
                        <h3 class="@(IsTaskPanelMinimized ? "text-xs" : "text-sm") font-bold text-white transition-all duration-200">Tasks</h3>
                    </div>
                    <div class="flex items-center gap-1.5">
                        <span class="material-symbols-outlined text-gray-400 transition-all duration-300 ease-out @(IsTaskPanelMinimized ? "text-base rotate-0" : "text-xl rotate-180")">expand_less</span>
                        <button @onclick="OpenAddTaskModal" @onclick:stopPropagation="true" 
                                class="flex items-center justify-center text-primary transition-all duration-200 ease-out active:scale-90 @(IsTaskPanelMinimized ? "size-6" : "size-8") hover:text-primary/80 hover:scale-105">
                            <span class="material-symbols-outlined @(IsTaskPanelMinimized ? "text-lg" : "text-2xl") transition-all duration-200">add_circle</span>
                        </button>
                    </div>
                </div>
                
                @* Task List - only visible when expanded *@
                @if (!IsTaskPanelMinimized)
                {
                    <ul class="flex flex-col gap-1 px-4 pt-1 pb-4 overflow-y-auto" style="max-height: calc(50vh - 56px);">
                        @if (TaskManager.Tasks.Count == 0)
                        {
                            <li class="flex flex-col items-center justify-center py-8 text-gray-400">
                                <span class="material-symbols-outlined text-3xl mb-2">task</span>
                                <p class="text-sm">No tasks yet</p>
                                <p class="text-xs text-gray-500 mt-1">Click + to add a new task</p>
                            </li>
                        }
                        @foreach (var task in TaskManager.Tasks)
                        {
                            <li class="flex h-16 items-center gap-4 rounded-lg p-3 @GetTaskItemClass(task) transition-colors">
                                <span class="material-symbols-outlined @GetTaskStatusIconClass(task.Status)">@GetTaskStatusIcon(task.Status)</span>
                                <div class="flex flex-1 flex-col min-w-0">
                                    <p class="truncate text-base font-medium leading-tight text-white">@task.Name</p>
                                    <p class="truncate text-xs text-gray-400">@task.LogFilePath</p>
                                </div>
                                @if (task.Status == StreamTaskStatus.Running)
                                {
                                    <button @onclick="() => StopTaskAsync(task.Id)" @onclick:stopPropagation="true"
                                            class="flex size-8 items-center justify-center text-amber-400 hover:text-amber-500 transition-colors">
                                        <span class="material-symbols-outlined text-xl">pause_circle</span>
                                    </button>
                                }
                                else
                                {
                                    @if (task.Status == StreamTaskStatus.Cancelled || task.Status == StreamTaskStatus.Completed || task.Status == StreamTaskStatus.Error)
                                    {
                                        <button @onclick="() => OpenEditTaskModalAsync(task.Id)" @onclick:stopPropagation="true"
                                                class="flex size-8 items-center justify-center text-gray-300 hover:text-white transition-colors">
                                            <span class="material-symbols-outlined text-xl">edit</span>
                                        </button>
                                    }
                                    <button @onclick="() => StartTaskAsync(task.Id)" @onclick:stopPropagation="true"
                                            class="flex size-8 items-center justify-center text-primary hover:text-primary/80 transition-colors">
                                        <span class="material-symbols-outlined text-xl">play_circle</span>
                                    </button>
                                }
                                <button @onclick="() => RemoveTaskAsync(task.Id)" @onclick:stopPropagation="true"
                                        class="flex size-8 items-center justify-center text-red-400 hover:text-red-500 transition-colors">
                                    <span class="material-symbols-outlined text-xl">delete</span>
                                </button>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

@* Add Task Modal *@
@if (_showAddTaskModal)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm">
        <div class="flex max-h-[90vh] w-[400px] max-w-[90vw] flex-col bg-[#1a1a1a] rounded-2xl shadow-2xl border border-[#2b2b2b] overflow-hidden"
             @onclick:stopPropagation="true">
            @* Modal Header *@
            <div class="flex items-center justify-between px-6 py-4 border-b border-[#2b2b2b]">
                <h2 class="text-lg font-bold text-white">@(_editingTaskId.HasValue ? "Edit Task" : "Add New Task")</h2>
                <button @onclick="CloseAddTaskModal" 
                        class="flex size-8 items-center justify-center rounded-full text-gray-400 hover:bg-white/10 hover:text-white transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            
            @* Modal Body *@
            <div class="flex flex-1 flex-col gap-3 overflow-y-auto p-6">
                @* Task Name *@
                <div class="flex flex-col gap-1.5">
                    <label class="text-sm font-medium text-gray-400">Task Name</label>
                    <input @bind="_newTaskName" 
                           class="h-11 w-full rounded-lg border border-[#3b3b3b] bg-[#262626] px-4 text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors"
                           placeholder="e.g., System Log Monitor" />
                </div>
                
                @* Log File Path *@
                <div class="flex flex-col gap-1.5">
                    <label class="text-sm font-medium text-gray-400">Log File Path</label>
                    <input @bind="_newTaskLogPath" 
                           class="h-11 w-full rounded-lg border border-[#3b3b3b] bg-[#262626] px-4 text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors font-mono text-sm"
                           placeholder="/var/log/syslog" />
                </div>
                
                @* Session Info (Read-only) *@
                <div class="flex flex-col gap-1.5">
                    <label class="text-sm font-medium text-gray-400">Target Session</label>
                    <div class="flex items-center gap-3 h-11 w-full rounded-lg border border-[#3b3b3b] bg-[#1e1e1e] px-4">
                        <span class="material-symbols-outlined text-primary text-lg">dns</span>
                        <span class="text-white text-sm">@(CurrentSession?.Name ?? "No session")</span>
                        <span class="text-gray-500 text-xs">(@(CurrentSession?.IpAddress ?? "N/A"):@(CurrentSession?.Port ?? 22))</span>
                    </div>
                </div>
                
                @* Auto Start Toggle *@
                <div class="flex items-center justify-between py-1">
                    <div class="flex flex-col">
                        <span class="text-sm font-medium text-white">Auto Start</span>
                        <span class="text-xs text-gray-500">Start streaming immediately after adding</span>
                    </div>
                    <button @onclick="() => _autoStartTask = !_autoStartTask"
                            class="relative h-6 w-11 rounded-full transition-colors @(_autoStartTask ? "bg-primary" : "bg-[#3b3b3b]")">
                        <span class="absolute top-1 h-4 w-4 rounded-full bg-white shadow transition-transform @(_autoStartTask ? "left-6" : "left-1")"></span>
                    </button>
                </div>
                
                @* Analyzer Options *@
                <div class="flex flex-col gap-1.5 py-1">
                    <span class="text-sm font-medium text-gray-400">Analyzers</span>
                    <div class="flex flex-col gap-1.5 rounded-lg border border-[#3b3b3b] bg-[#1e1e1e] p-3">
                        @* Drain Log Parser *@
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-cyan-400 text-lg">hub</span>
                                <div class="flex flex-col">
                                    <span class="text-sm text-white">Drain Log Parser</span>
                                    <span class="text-xs text-gray-500">Log clustering & pattern extraction</span>
                                </div>
                            </div>
                            <button @onclick="() => _useDrainParser = !_useDrainParser"
                                    class="relative h-5 w-9 rounded-full transition-colors @(_useDrainParser ? "bg-cyan-500" : "bg-[#3b3b3b]")">
                                <span class="absolute top-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform @(_useDrainParser ? "left-4" : "left-0.5")"></span>
                            </button>
                        </div>
                        
                        @* Transaction Analyzer *@
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-amber-400 text-lg">swap_horiz</span>
                                <div class="flex flex-col">
                                    <span class="text-sm text-white">Transaction Analyzer</span>
                                    <span class="text-xs text-gray-500">Transaction tracking & analysis</span>
                                </div>
                            </div>
                            <button @onclick="() => _useTransactionAnalyzer = !_useTransactionAnalyzer"
                                    class="relative h-5 w-9 rounded-full transition-colors @(_useTransactionAnalyzer ? "bg-amber-500" : "bg-[#3b3b3b]")">
                                <span class="absolute top-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform @(_useTransactionAnalyzer ? "left-4" : "left-0.5")"></span>
                            </button>
                        </div>
                        
                        @* Equipment Analyzer *@
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-green-400 text-lg">precision_manufacturing</span>
                                <div class="flex flex-col">
                                    <span class="text-sm text-white">Equipment Analyzer</span>
                                    <span class="text-xs text-gray-500">Equipment state monitoring</span>
                                </div>
                            </div>
                            <button @onclick="() => _useEquipmentAnalyzer = !_useEquipmentAnalyzer"
                                    class="relative h-5 w-9 rounded-full transition-colors @(_useEquipmentAnalyzer ? "bg-green-500" : "bg-[#3b3b3b]")">
                                <span class="absolute top-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform @(_useEquipmentAnalyzer ? "left-4" : "left-0.5")"></span>
                            </button>
                        </div>
                        
                        @* Persist Logs *@
                        <div class="flex items-center justify-between border-t border-[#3b3b3b] pt-2 mt-1">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-purple-400 text-lg">database</span>
                                <div class="flex flex-col">
                                    <span class="text-sm text-white">Persist Logs</span>
                                    <span class="text-xs text-gray-500">Save logs to database</span>
                                </div>
                            </div>
                            <button @onclick="() => _persistLogs = !_persistLogs"
                                    class="relative h-5 w-9 rounded-full transition-colors @(_persistLogs ? "bg-purple-500" : "bg-[#3b3b3b]")">
                                <span class="absolute top-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform @(_persistLogs ? "left-4" : "left-0.5")"></span>
                            </button>
                        </div>
                    </div>
                </div>

                @* Filter Options *@
                <div class="flex flex-col gap-1.5 py-1">
                    <span class="text-sm font-medium text-gray-400">Filter (Optional)</span>
                    <div class="flex flex-col gap-2 rounded-lg border border-[#3b3b3b] bg-[#1e1e1e] p-3">
                        <div class="flex items-center justify-between">
                            <div class="flex flex-col">
                                <span class="text-sm text-white">Mode</span>
                                <span class="text-xs text-gray-500">Text or Regex</span>
                            </div>
                            <div class="flex h-8 items-center rounded-lg border border-[#3b3b3b] bg-[#262626] p-1">
                                <button type="button" @onclick="() => _filterKind = LogStreamFilterKind.FixedString"
                                        class="h-6 px-3 rounded-md text-xs font-medium transition-colors @(_filterKind == LogStreamFilterKind.FixedString ? "bg-primary text-white" : "text-gray-400 hover:bg-white/5")">
                                    Text
                                </button>
                                <button type="button" @onclick="() => _filterKind = LogStreamFilterKind.Regex"
                                        class="h-6 px-3 rounded-md text-xs font-medium transition-colors @(_filterKind == LogStreamFilterKind.Regex ? "bg-primary text-white" : "text-gray-400 hover:bg-white/5")">
                                    Regex
                                </button>
                            </div>
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <div class="flex items-center justify-between">
                                <label class="text-sm font-medium text-gray-400">Include</label>
                                <button type="button" @onclick="AddIncludePattern"
                                        class="flex h-8 w-8 items-center justify-center rounded-md border border-[#3b3b3b] bg-[#262626] text-gray-300 hover:bg-white/5">
                                    <span class="material-symbols-outlined text-lg">add</span>
                                </button>
                            </div>

                            @for (var i = 0; i < _filterIncludePatterns.Count; i++)
                            {
                                <div class="flex items-center gap-2">
                                    <input value="@_filterIncludePatterns[i]"
                                           @oninput="e => _filterIncludePatterns[i] = e.Value?.ToString() ?? string.Empty"
                                           class="h-11 min-w-0 flex-1 rounded-lg border border-[#3b3b3b] bg-[#262626] px-4 text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors font-mono text-sm"
                                           placeholder="e.g., ERROR" />
                                    <button type="button" @onclick="() => RemoveIncludePattern(i)"
                                            class="flex h-11 w-11 items-center justify-center rounded-lg border border-[#3b3b3b] bg-[#262626] text-gray-300 hover:bg-white/5">
                                        <span class="material-symbols-outlined text-xl">remove_circle</span>
                                    </button>
                                </div>
                            }
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <div class="flex items-center justify-between">
                                <label class="text-sm font-medium text-gray-400">Exclude</label>
                                <button type="button" @onclick="AddExcludePattern"
                                        class="flex h-8 w-8 items-center justify-center rounded-md border border-[#3b3b3b] bg-[#262626] text-gray-300 hover:bg-white/5">
                                    <span class="material-symbols-outlined text-lg">add</span>
                                </button>
                            </div>

                            @for (var i = 0; i < _filterExcludePatterns.Count; i++)
                            {
                                <div class="flex items-center gap-2">
                                    <input value="@_filterExcludePatterns[i]"
                                           @oninput="e => _filterExcludePatterns[i] = e.Value?.ToString() ?? string.Empty"
                                           class="h-11 min-w-0 flex-1 rounded-lg border border-[#3b3b3b] bg-[#262626] px-4 text-white placeholder:text-gray-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors font-mono text-sm"
                                           placeholder="e.g., healthcheck" />
                                    <button type="button" @onclick="() => RemoveExcludePattern(i)"
                                            class="flex h-11 w-11 items-center justify-center rounded-lg border border-[#3b3b3b] bg-[#262626] text-gray-300 hover:bg-white/5">
                                        <span class="material-symbols-outlined text-xl">remove_circle</span>
                                    </button>
                                </div>
                            }
                        </div>

                        <div class="flex items-center justify-between">
                            <div class="flex flex-col">
                                <span class="text-sm text-white">Ignore Case</span>
                                <span class="text-xs text-gray-500">Case-insensitive match</span>
                            </div>
                            <button @onclick="() => _filterIgnoreCase = !_filterIgnoreCase"
                                    class="relative h-5 w-9 rounded-full transition-colors @(_filterIgnoreCase ? "bg-primary" : "bg-[#3b3b3b]")">
                                <span class="absolute top-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform @(_filterIgnoreCase ? "left-4" : "left-0.5")"></span>
                            </button>
                        </div>

                        <div class="flex items-center justify-between border-t border-[#3b3b3b] pt-2 mt-1">
                            <div class="flex flex-col">
                                <span class="text-sm text-white">Invert Match</span>
                                <span class="text-xs text-gray-500">Equivalent to grep -v (include)</span>
                            </div>
                            <button @onclick="() => _filterInvertMatch = !_filterInvertMatch"
                                    class="relative h-5 w-9 rounded-full transition-colors @(_filterInvertMatch ? "bg-primary" : "bg-[#3b3b3b]")">
                                <span class="absolute top-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform @(_filterInvertMatch ? "left-4" : "left-0.5")"></span>
                            </button>
                        </div>
                    </div>
                </div>
                
                @* Error Message *@
                @if (!string.IsNullOrEmpty(_addTaskError))
                {
                    <div class="flex items-center gap-2 rounded-lg bg-red-500/10 px-4 py-3 text-red-400">
                        <span class="material-symbols-outlined text-lg">error</span>
                        <span class="text-sm">@_addTaskError</span>
                    </div>
                }
            </div>
            
            @* Modal Footer *@
            <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-[#2b2b2b]">
                <button @onclick="CloseAddTaskModal"
                        class="h-10 px-5 rounded-lg text-sm font-medium text-gray-400 hover:bg-white/5 hover:text-white transition-colors">
                    Cancel
                </button>
                <button @onclick="SaveTaskAsync"
                        class="h-10 px-5 rounded-lg bg-primary text-sm font-medium text-white hover:bg-primary/80 transition-colors">
                    @(_editingTaskId.HasValue ? "Save" : "Add Task")
                </button>
            </div>
        </div>
    </div>
}

@code {
#nullable enable
    [Parameter]
    public int SessionId { get; set; }

    private SshSession? CurrentSession { get; set; }
    private ElementReference LogEntriesContainerRef;

    private readonly List<LogEntry> LogEntries = new();
    private const int MaxLogEntries = 500;
    private string LogPath { get; set; } = "/var/log/supervisord/supervisord.log";
    private string LogSearchTerm { get; set; } = string.Empty;
    private string LogFilter { get; set; } = "All";
    private string? LogStreamErrorMessage { get; set; }
    private CancellationTokenSource _cts = new();

    // Task Panel State
    private bool IsTaskPanelMinimized { get; set; } = true;
    private double _touchStartY;
    private double _touchCurrentY;
    private bool _isDragging;
    
    // Add Task Modal State
    private bool _showAddTaskModal;
    private Guid? _editingTaskId;
    private string _newTaskName = string.Empty;
    private string _newTaskLogPath = "/var/log/syslog";
    private bool _autoStartTask = true;
    private string? _addTaskError;
    
    // Analyzer Options
    private bool _useDrainParser = true;
    private bool _useTransactionAnalyzer = true;
    private bool _useEquipmentAnalyzer = true;
    private bool _persistLogs = true;

    // Filter Options
    private LogStreamFilterKind _filterKind = LogStreamFilterKind.FixedString;
    private readonly List<string> _filterIncludePatterns = new() { string.Empty };
    private readonly List<string> _filterExcludePatterns = new() { string.Empty };
    private bool _filterIgnoreCase = true;
    private bool _filterInvertMatch;

    private void AddIncludePattern() => _filterIncludePatterns.Add(string.Empty);
    private void AddExcludePattern() => _filterExcludePatterns.Add(string.Empty);

    private void RemoveIncludePattern(int index)
    {
        if (index < 0 || index >= _filterIncludePatterns.Count)
        {
            return;
        }

        if (_filterIncludePatterns.Count == 1)
        {
            _filterIncludePatterns[0] = string.Empty;
            return;
        }

        _filterIncludePatterns.RemoveAt(index);
    }

    private void RemoveExcludePattern(int index)
    {
        if (index < 0 || index >= _filterExcludePatterns.Count)
        {
            return;
        }

        if (_filterExcludePatterns.Count == 1)
        {
            _filterExcludePatterns[0] = string.Empty;
            return;
        }

        _filterExcludePatterns.RemoveAt(index);
    }

    private static List<string> NormalizePatterns(IEnumerable<string> patterns)
    {
        return patterns
            .Select(p => (p ?? string.Empty).Trim())
            .Where(p => p.Length > 0)
            .ToList();
    }

    private static readonly Regex LogLineRegex = new(@"^\[(?<timestamp>[^\]]+)\]\s*\[(?<level>[A-Z]+)\]\s*(?<message>.*)$",
        RegexOptions.Compiled);
    private static readonly Dictionary<string, string> LevelColorMap = new(StringComparer.OrdinalIgnoreCase)
    {
