    private IEnumerable<LogEntry> FilteredLogEntries => LogEntries
        .Where(e => LogFilter == "All" || e.Level.Equals(LogFilter, StringComparison.OrdinalIgnoreCase))
        .Where(e => string.IsNullOrEmpty(LogSearchTerm) || 
                    e.Message.Contains(LogSearchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        RegisterLogStreamHandlers();

        CurrentSession = SelectedSessionStore.Current;
        if (CurrentSession == null)
        {
            List<SshSession> sessions = await SessionManager.GetSessionsAsync();
            if (SessionId > 0 && SessionId <= sessions.Count)
            {
                CurrentSession = sessions[SessionId - 1];
            }
        }

        // Load saved tasks from storage
        if (CurrentSession != null)
        {
            await LoadSavedTasksAsync();
        }

        // Add sample log entries for demo
        LogEntries.Add(new LogEntry("10:45:12 AM", "ERROR", "Connection to API failed: Timeout"));
        LogEntries.Add(new LogEntry("10:44:58 AM", "WARN", "Deprecated function call - 'getUser' is deprecated"));
        LogEntries.Add(new LogEntry("10:44:30 AM", "INFO", "Data sync complete - Processed 1,423 records"));
        LogEntries.Add(new LogEntry("10:42:01 AM", "INFO", "Starting daily data sync..."));
        LogEntries.Add(new LogEntry("10:41:15 AM", "CRITICAL", "Database Unreachable - Service cannot connect"));

        await base.OnInitializedAsync();
    }

    private async Task LoadSavedTasksAsync()
    {
        if (CurrentSession == null) return;
        
        var sessionsWithTasks = await SessionStorage.LoadWithTasksAsync();
        var sessionWithTasks = sessionsWithTasks.FirstOrDefault(s => 
            s.Host == CurrentSession.Host && 
            s.Port == CurrentSession.Port && 
            s.Username == CurrentSession.Username);
            
        if (sessionWithTasks == null) return;
        
        foreach (var savedTask in sessionWithTasks.Tasks)
        {
            var normalizedSavedLogPath = NormalizeLogFilePath(savedTask.LogFilePath);

            var alreadyRegistered = TaskManager.Tasks.Any(t =>
                IsSameSession(t.Session, CurrentSession) &&
                string.Equals(NormalizeLogFilePath(t.LogFilePath), normalizedSavedLogPath, StringComparison.OrdinalIgnoreCase));

            if (alreadyRegistered)
            {
                continue;
            }

            var analyzerOptions = new TaskAnalyzerOptions
            {
                UseDrainLogParser = savedTask.UseDrainLogParser,
                UseTransactionAnalyzer = savedTask.UseTransactionAnalyzer,
                UseEquipmentAnalyzer = savedTask.UseEquipmentAnalyzer,
                PersistLogs = savedTask.PersistLogs
            };

            var filterOptions = savedTask.ToFilterOptions();
            var task = TaskFactory.CreateTask(CurrentSession, savedTask.LogFilePath, savedTask.Name, analyzerOptions, filterOptions);
            TaskManager.AddTask(task);
            
            // Auto-start if configured and session is connected
            if (savedTask.AutoStart && CurrentSession.IsConnected)
            {
                _ = task.StartAsync();
            }
        }
    }

    private static bool IsSameSession(SshSession a, SshSession b)
    {
        return string.Equals(a.Host, b.Host, StringComparison.OrdinalIgnoreCase)
            && a.Port == b.Port
            && string.Equals(a.Username, b.Username, StringComparison.Ordinal);
    }

    private static string NormalizeLogFilePath(string? path)
    {
        return (path ?? string.Empty).Trim();
    }

