@page "/"
@using NexusWorks.Guardian.Models

<div class="gw-home flex min-h-full flex-1 flex-col gap-4 lg:gap-6">
    <div class="mx-auto w-full max-w-[1600px]">
        <section class="gw-home-primary grid gap-4 xl:grid-cols-[minmax(0,1.02fr)_minmax(22rem,0.98fr)] 2xl:grid-cols-[minmax(0,1.08fr)_minmax(24rem,0.92fr)]">
        <div class="gw-home-pane gw-panel p-5 lg:p-6">
            <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-400">Execution Setup</p>
                    <h2 class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-slate-950">Run a Guardian inspection</h2>
                    <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">
                        Enter current root, patch root, baseline workbook, and output root. The run generates HTML and Excel artifacts and hydrates the in-app review console.
                    </p>
                </div>

                <div class="flex w-full flex-wrap items-center justify-start gap-2 xl:w-auto xl:justify-end">
                    @if (HasSampleDataset)
                    {
                        <button type="button" class="gw-button-secondary" @onclick="LoadSampleDatasetAsync" disabled="@_isRunning">
                            <span class="material-symbols-outlined text-[18px]">science</span>
                            Load sample data
                        </button>
                        <button type="button" class="gw-button-secondary" @onclick="OpenSampleGuideAsync" disabled="@_isRunning">
                            <span class="material-symbols-outlined text-[18px]">description</span>
                            Open sample guide
                        </button>
                    }
                    <span class="gw-badge bg-blue-50 text-blue-700 ring-1 ring-inset ring-blue-200">Phase 3 UI</span>
                </div>
            </div>

            <EditForm Model="_runForm" OnValidSubmit="RunCompareAsync" class="mt-6 grid gap-4">
                <DataAnnotationsValidator />

                <div class="gw-home-form-grid grid gap-4">
                    <div class="gw-home-form-full space-y-2">
                        <label class="gw-label" for="reportTitle">Report title</label>
                        <InputText id="reportTitle" @bind-Value="_runForm.ReportTitle" class="gw-input" />
                        <ValidationMessage For="@(() => _runForm.ReportTitle)" class="gw-validation" />
                    </div>

                    <div class="space-y-3">
                        <div class="flex items-center justify-between gap-3">
                            <label class="gw-label" for="currentRoot">Current input</label>
                            <InputSelect @bind-Value="_runForm.CurrentMode" class="gw-input max-w-[10rem] text-sm">
                                <option value="@InputSourceMode.Local">Local</option>
                                <option value="@InputSourceMode.Sftp">SFTP</option>
                            </InputSelect>
                        </div>
                        <PathInputField Id="currentRoot" @bind-Value="_runForm.CurrentRootPath"
                                        OnBrowseClicked='() => BrowseFolderAsync(PathField.CurrentRoot)'
                                        OnOpenClicked='() => OpenPathAsync(_runForm.CurrentRootPath)' CanOpen="@CanOpenCurrentRoot" IsDisabled="@_isRunning"
                                        Badge="CurrentRootBadge"
                                        RecentPaths="_recentCurrentRoots" RecentPlaceholder="Recent current roots"
                                        OnRecentPathSelected="path => ApplyRecentPathAsync(PathField.CurrentRoot, path)" />

                        @if (IsCurrentSftp)
                        {
                            <div class="grid gap-3 rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
                                <div class="grid gap-3 sm:grid-cols-2">
                                    <div class="space-y-2">
                                        <label class="gw-label" for="currentSftpHost">Current SFTP host</label>
                                        <InputText id="currentSftpHost" @bind-Value="_runForm.CurrentSftpHost" class="gw-input" />
                                    </div>
                                    <div class="space-y-2">
                                        <label class="gw-label" for="currentSftpPort">Current SFTP port</label>
                                        <InputNumber id="currentSftpPort" @bind-Value="_runForm.CurrentSftpPort" class="gw-input" />
                                    </div>
                                    <div class="space-y-2">
                                        <label class="gw-label" for="currentSftpUsername">Current SFTP username</label>
                                        <InputText id="currentSftpUsername" @bind-Value="_runForm.CurrentSftpUsername" class="gw-input" />
                                    </div>
                                    <div class="space-y-2">
                                        <label class="gw-label" for="currentSftpAuthenticationMode">Current auth mode</label>
                                        <InputSelect id="currentSftpAuthenticationMode" @bind-Value="_runForm.CurrentSftpAuthenticationMode" class="gw-input">
                                            <option value="@SftpAuthenticationMode.Password">Password</option>
                                            <option value="@SftpAuthenticationMode.PrivateKey">Private key</option>
                                        </InputSelect>
                                    </div>
                                </div>
                                @if (_runForm.CurrentSftpAuthenticationMode == SftpAuthenticationMode.Password)
                                {
                                    <div class="space-y-2">
                                        <label class="gw-label" for="currentSftpPassword">Current SFTP password</label>
                                        <input id="currentSftpPassword" @bind="_runForm.CurrentSftpPassword" type="password" class="gw-input" />
                                    </div>
                                }
                                else
                                {
                                    <div class="grid gap-3 sm:grid-cols-2">
                                        <div class="space-y-2">
                                            <label class="gw-label" for="currentSftpPrivateKeyPath">Current private key path</label>
                                            <InputText id="currentSftpPrivateKeyPath" @bind-Value="_runForm.CurrentSftpPrivateKeyPath" class="gw-input" />
                                        </div>
                                        <div class="space-y-2">
                                            <label class="gw-label" for="currentSftpPrivateKeyPassphrase">Current private key passphrase (optional)</label>
                                            <input id="currentSftpPrivateKeyPassphrase" @bind="_runForm.CurrentSftpPrivateKeyPassphrase" type="password" class="gw-input" />
                                        </div>
                                    </div>
                                }
                                <div class="space-y-2">
                                    <label class="gw-label" for="currentSftpRemoteRoot">Current remote root</label>
                                    <InputText id="currentSftpRemoteRoot" @bind-Value="_runForm.CurrentSftpRemoteRoot" class="gw-input" />
                                </div>
                                <div class="space-y-2">
                                    <label class="gw-label" for="currentSftpFingerprint">Current host fingerprint (optional)</label>
                                    <InputText id="currentSftpFingerprint" @bind-Value="_runForm.CurrentSftpFingerprint" class="gw-input" />
                                </div>
                                <label class="flex items-center gap-2 text-sm text-slate-600">
                                    <InputCheckbox @bind-Value="_runForm.CurrentSftpClearTargetBeforeDownload" />
                                    <span>Clear current target folder before download</span>
                                </label>
                            </div>
                        }
                    </div>

                    <div class="space-y-3">
                        <div class="flex items-center justify-between gap-3">
                            <label class="gw-label" for="patchRoot">Patch input</label>
                            <InputSelect @bind-Value="_runForm.PatchMode" class="gw-input max-w-[10rem] text-sm">
                                <option value="@InputSourceMode.Local">Local</option>
                                <option value="@InputSourceMode.Sftp">SFTP</option>
                            </InputSelect>
                        </div>
                        <PathInputField Id="patchRoot" @bind-Value="_runForm.PatchRootPath"
                                        OnBrowseClicked='() => BrowseFolderAsync(PathField.PatchRoot)'
                                        OnOpenClicked='() => OpenPathAsync(_runForm.PatchRootPath)' CanOpen="@CanOpenPatchRoot" IsDisabled="@_isRunning"
                                        Badge="PatchRootBadge"
                                        RecentPaths="_recentPatchRoots" RecentPlaceholder="Recent patch roots"
                                        OnRecentPathSelected="path => ApplyRecentPathAsync(PathField.PatchRoot, path)" />

                        @if (IsPatchSftp)
                        {
                            <div class="grid gap-3 rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
                                <label class="flex items-center gap-2 text-sm text-slate-600">
                                    <InputCheckbox @bind-Value="_runForm.PatchUseCurrentSftpConnection" />
                                    <span>Use current-side SFTP connection</span>
                                </label>

                                @if (_runForm.PatchUseCurrentSftpConnection)
                                {
                                    <div class="rounded-2xl border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-700">
                                        Patch download will reuse current-side host, username, fingerprint, and authentication settings.
                                    </div>
                                }

                                @if (!_runForm.PatchUseCurrentSftpConnection)
                                {
                                    <div class="grid gap-3 sm:grid-cols-2">
                                        <div class="space-y-2">
                                            <label class="gw-label" for="patchSftpHost">Patch SFTP host</label>
                                            <InputText id="patchSftpHost" @bind-Value="_runForm.PatchSftpHost" class="gw-input" />
                                        </div>
                                        <div class="space-y-2">
                                            <label class="gw-label" for="patchSftpPort">Patch SFTP port</label>
                                            <InputNumber id="patchSftpPort" @bind-Value="_runForm.PatchSftpPort" class="gw-input" />
                                        </div>
                                        <div class="space-y-2">
                                            <label class="gw-label" for="patchSftpUsername">Patch SFTP username</label>
                                            <InputText id="patchSftpUsername" @bind-Value="_runForm.PatchSftpUsername" class="gw-input" />
                                        </div>
                                        <div class="space-y-2">
                                            <label class="gw-label" for="patchSftpAuthenticationMode">Patch auth mode</label>
                                            <InputSelect id="patchSftpAuthenticationMode" @bind-Value="_runForm.PatchSftpAuthenticationMode" class="gw-input">
                                                <option value="@SftpAuthenticationMode.Password">Password</option>
                                                <option value="@SftpAuthenticationMode.PrivateKey">Private key</option>
                                            </InputSelect>
                                        </div>
                                    </div>
                                    @if (_runForm.PatchSftpAuthenticationMode == SftpAuthenticationMode.Password)
                                    {
                                        <div class="space-y-2">
                                            <label class="gw-label" for="patchSftpPassword">Patch SFTP password</label>
                                            <input id="patchSftpPassword" @bind="_runForm.PatchSftpPassword" type="password" class="gw-input" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="grid gap-3 sm:grid-cols-2">
                                            <div class="space-y-2">
                                                <label class="gw-label" for="patchSftpPrivateKeyPath">Patch private key path</label>
                                                <InputText id="patchSftpPrivateKeyPath" @bind-Value="_runForm.PatchSftpPrivateKeyPath" class="gw-input" />
                                            </div>
                                            <div class="space-y-2">
                                                <label class="gw-label" for="patchSftpPrivateKeyPassphrase">Patch private key passphrase (optional)</label>
                                                <input id="patchSftpPrivateKeyPassphrase" @bind="_runForm.PatchSftpPrivateKeyPassphrase" type="password" class="gw-input" />
                                            </div>
                                        </div>
                                    }
                                    <div class="space-y-2">
                                        <label class="gw-label" for="patchSftpFingerprint">Patch host fingerprint (optional)</label>
                                        <InputText id="patchSftpFingerprint" @bind-Value="_runForm.PatchSftpFingerprint" class="gw-input" />
                                    </div>
                                }
                                <div class="space-y-2">
                                    <label class="gw-label" for="patchSftpRemoteRoot">Patch remote root</label>
                                    <InputText id="patchSftpRemoteRoot" @bind-Value="_runForm.PatchSftpRemoteRoot" class="gw-input" />
                                </div>
                                <label class="flex items-center gap-2 text-sm text-slate-600">
                                    <InputCheckbox @bind-Value="_runForm.PatchSftpClearTargetBeforeDownload" />
                                    <span>Clear patch target folder before download</span>
                                </label>
                            </div>
                        }
                    </div>

                    <div class="gw-home-form-full space-y-2">
                        <label class="gw-label" for="baselinePath">Baseline workbook</label>
                        <PathInputField Id="baselinePath" @bind-Value="_runForm.BaselinePath" @bind-Value:after="OnBaselinePathChangedAsync"
                                        OnBrowseClicked="BrowseBaselineAsync"
                                        OnOpenClicked='() => OpenPathAsync(_runForm.BaselinePath)' CanOpen="@CanOpenBaselinePath" IsDisabled="@_isRunning"
                                        Badge="BaselinePathBadge"
                                        RecentPaths="_recentBaselinePaths" RecentPlaceholder="Recent baseline files"
                                        OnRecentPathSelected="path => ApplyRecentPathAsync(PathField.BaselinePath, path)" />
                    </div>

                    <div class="gw-home-form-full space-y-2">
                        <label class="gw-label" for="outputRoot">Output root</label>
                        <PathInputField Id="outputRoot" @bind-Value="_runForm.OutputRootPath" @bind-Value:after="OnOutputRootChangedAsync"
                                        OnBrowseClicked='() => BrowseFolderAsync(PathField.OutputRoot)'
                                        OnOpenClicked='() => OpenPathAsync(_runForm.OutputRootPath)' CanOpen="@CanOpenOutputRoot" IsDisabled="@_isRunning"
                                        Badge="OutputRootBadge"
                                        RecentPaths="_recentOutputRoots" RecentPlaceholder="Recent output roots"
                                        OnRecentPathSelected="path => ApplyRecentPathAsync(PathField.OutputRoot, path)" />
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                        @_errorMessage
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_noticeMessage))
                {
                    <div class="@($"rounded-2xl border px-4 py-3 text-sm {NoticeBannerClass}")">
                        <div class="flex items-start justify-between gap-3">
                            <div class="flex items-start gap-2">
                                <span class="material-symbols-outlined text-[18px]">@NoticeIcon</span>
                                <span>@_noticeMessage</span>
                            </div>
                            <button type="button" class="gw-button-secondary px-3 py-1 text-xs" @onclick="ClearNotice">
                                Dismiss
                            </button>
                        </div>
                    </div>
                }

                @if (_baselinePreview is not null || !string.IsNullOrWhiteSpace(_baselinePreviewError))
                {
                    <div class="rounded-3xl border border-slate-200 bg-slate-50/80 p-4">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Baseline Preview</div>
                                <div class="mt-1 text-sm text-slate-600">Quick validation and rule summary for the selected workbook.</div>
                            </div>
                            <span class="gw-badge @(_baselinePreview is null ? "bg-red-100 text-red-700 ring-1 ring-inset ring-red-200" : "bg-emerald-100 text-emerald-700 ring-1 ring-inset ring-emerald-200")">
                                @(_baselinePreview is null ? "Invalid" : "Loaded")
                            </span>
                        </div>

                        @if (_baselinePreview is not null)
                        {
                            <div class="mt-4 grid gap-3 sm:grid-cols-3">
                                <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3">
                                    <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Rules</div>
                                    <div class="mt-2 text-lg font-semibold text-slate-900">@_baselinePreview.TotalRuleCount</div>
                                </div>
                                <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3">
                                    <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Required</div>
                                    <div class="mt-2 text-lg font-semibold text-slate-900">@_baselinePreview.RequiredRuleCount</div>
                                </div>
                                <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3">
                                    <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Excluded</div>
                                    <div class="mt-2 text-lg font-semibold text-slate-900">@_baselinePreview.ExcludedRuleCount</div>
                                </div>
                            </div>

                            <div class="mt-4 flex flex-wrap gap-2">
                                @foreach (var pair in _baselinePreview.FileTypeCounts)
                                {
                                    <span class="gw-badge bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200">@($"{pair.Key} {pair.Value}")</span>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="mt-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@_baselinePreviewError</div>
                        }
                    </div>
                }

                <div class="rounded-3xl border border-slate-200 bg-white p-4">
                    <div class="flex flex-wrap items-start justify-between gap-3">
                        <div>
                            <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Run Readiness</div>
                            <div class="mt-1 text-sm text-slate-600">@RunReadiness.Description</div>
                        </div>
                        <span class="gw-badge @RunReadiness.BadgeClass">@RunReadiness.Label</span>
                    </div>
                </div>

                <div class="gw-home-run-actions grid gap-3">
                    <div class="gw-action-cluster">
                        <button type="submit" class="gw-button" disabled="@(!CanRunCompare)">
                            <span class="material-symbols-outlined text-[18px]">play_arrow</span>
                            @(_isRunning ? "Running compare" : "Run compare")
                        </button>
                        <button type="button" class="gw-button-secondary" @onclick="RerunAsync" disabled="@(!HasReport || !CanRunCompare)">
                            <span class="material-symbols-outlined text-[18px]">refresh</span>
                            Rerun
                        </button>
                    </div>

                    <div class="gw-home-report-actions gw-home-run-secondary gw-action-cluster">
                        <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(_report?.Artifacts.HtmlReportPath)' disabled="@(!CanOpenReportHtml)">
                            <span class="material-symbols-outlined text-[18px]">web</span>
                            Open HTML
                        </button>
                        <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(_report?.Artifacts.ExcelReportPath)' disabled="@(!CanOpenReportExcel)">
                            <span class="material-symbols-outlined text-[18px]">table_view</span>
                            Open Excel
                        </button>
                        <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(_report?.Artifacts.JsonResultPath)' disabled="@(!CanOpenReportJson)">
                            <span class="material-symbols-outlined text-[18px]">data_object</span>
                            Open JSON
                        </button>
                        <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(_report?.Artifacts.LogPath)' disabled="@(!CanOpenReportLog)">
                            <span class="material-symbols-outlined text-[18px]">article</span>
                            Open Log
                        </button>
                        <button type="button" class="gw-button-secondary" @onclick='() => OpenPathAsync(_report?.Artifacts.OutputDirectory)' disabled="@(!CanOpenReportOutputDirectory)">
                            <span class="material-symbols-outlined text-[18px]">folder_open</span>
                            Open Output
                        </button>
                        <button type="button" class="gw-button-secondary" @onclick="RefreshHistoryFromToolbarAsync" disabled="@_isRunning">
                            <span class="material-symbols-outlined text-[18px]">history</span>
                            Refresh history
                        </button>
                    </div>

                    <details class="gw-home-report-drawer">
                        <summary class="gw-button-secondary">
                            <span class="material-symbols-outlined text-[18px]">dashboard_customize</span>
                            Reports & history
                        </summary>
                        <div class="gw-home-report-drawer-panel">
                            <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(_report?.Artifacts.HtmlReportPath)' disabled="@(!CanOpenReportHtml)">
                                <span class="material-symbols-outlined text-[18px]">web</span>
                                Open HTML
                            </button>
                            <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(_report?.Artifacts.ExcelReportPath)' disabled="@(!CanOpenReportExcel)">
                                <span class="material-symbols-outlined text-[18px]">table_view</span>
                                Open Excel
                            </button>
                            <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(_report?.Artifacts.JsonResultPath)' disabled="@(!CanOpenReportJson)">
                                <span class="material-symbols-outlined text-[18px]">data_object</span>
                                Open JSON
                            </button>
                            <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(_report?.Artifacts.LogPath)' disabled="@(!CanOpenReportLog)">
                                <span class="material-symbols-outlined text-[18px]">article</span>
                                Open Log
                            </button>
                            <button type="button" class="gw-button-secondary" @onclick='() => OpenPathAsync(_report?.Artifacts.OutputDirectory)' disabled="@(!CanOpenReportOutputDirectory)">
                                <span class="material-symbols-outlined text-[18px]">folder_open</span>
                                Open Output
                            </button>
                            <button type="button" class="gw-button-secondary" @onclick="RefreshHistoryFromToolbarAsync" disabled="@_isRunning">
                                <span class="material-symbols-outlined text-[18px]">history</span>
                                Refresh history
                            </button>
                        </div>
                    </details>
                </div>

                <div class="gw-home-shortcuts mt-3 flex flex-wrap items-center gap-2 text-xs text-slate-500">
                    <button type="button" class="gw-home-shortcut-primary gw-badge bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200" @onclick="ShowShortcutOverlay">
                        Shortcuts
                    </button>
                    <span class="gw-home-shortcut-primary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">Ctrl/Cmd+Enter Run</span>
                    <span class="gw-home-shortcut-primary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">Ctrl/Cmd+Shift+Enter Rerun</span>
                    <span class="gw-home-shortcut-secondary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">Alt+Shift+H History</span>
                    @if (HasSampleDataset)
                    {
                        <span class="gw-home-shortcut-secondary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">Alt+Shift+S Sample</span>
                    }
                    <span class="gw-home-shortcut-secondary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">[ / ] History</span>
                    <span class="gw-home-shortcut-secondary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">M Load History</span>
                    <span class="gw-home-shortcut-primary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">/ Search</span>
                    <span class="gw-home-shortcut-secondary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">1-5 Filters</span>
                    <span class="gw-home-shortcut-primary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">J/K or N/P Navigate</span>
                    <span class="gw-home-shortcut-secondary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">X Toggle Row</span>
                    <span class="gw-home-shortcut-secondary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">Alt+Shift+A/R/C Queue</span>
                    <span class="gw-home-shortcut-primary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">O / Shift+O Open File</span>
                    <span class="gw-home-shortcut-secondary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">Alt+Shift+O/P Bulk Open</span>
                    <span class="gw-home-shortcut-secondary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">H/E/D/L/U Reports</span>
                    <span class="gw-home-shortcut-primary gw-badge bg-white text-slate-600 ring-1 ring-inset ring-slate-200">? Help</span>
                </div>
            </EditForm>
        </div>

        <div class="gw-home-pane gw-panel p-5 lg:p-6">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-400">Run Summary</p>
                    <h2 class="mt-2 text-xl font-semibold tracking-[-0.03em] text-slate-950">Execution health</h2>
                </div>
                @if (HasReport)
                {
                    <span class="gw-badge bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200">Artifacts Ready</span>
                }
            </div>

            @if (HasReport)
            {
                <div class="mt-5 grid gap-4 sm:grid-cols-2 xl:grid-cols-2">
                    @foreach (var card in SummaryCards)
                    {
                        <article class="gw-kpi-card">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <div class="text-sm font-medium text-slate-500">@card.Title</div>
                                    <div class="mt-3 text-3xl font-semibold tracking-[-0.05em] text-slate-950">@card.Value</div>
                                </div>
                                <span class="gw-badge @card.BadgeClass">@card.Badge</span>
                            </div>
                            <p class="mt-3 text-xs leading-5 text-slate-500">@card.Note</p>
                        </article>
                    }
                </div>

                <div class="mt-5 space-y-3 rounded-3xl border border-slate-200 bg-slate-50/90 p-4">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                            <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Execution ID</div>
                            <div class="gw-code mt-2">@_report!.Summary.ExecutionId</div>
                        </div>
                        <div class="text-right text-sm text-slate-500">
                            <div>Completed</div>
                            <div class="mt-1 font-semibold text-slate-700">@_report.Summary.CompletedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                        </div>
                    </div>
                    <div class="space-y-2 text-sm text-slate-600">
                        <div><span class="font-semibold text-slate-800">Output:</span> <span class="font-mono text-xs">@_report.Artifacts.OutputDirectory</span></div>
                        <div><span class="font-semibold text-slate-800">HTML:</span> <span class="font-mono text-xs">@_report.Artifacts.HtmlReportPath</span></div>
                        <div><span class="font-semibold text-slate-800">Excel:</span> <span class="font-mono text-xs">@_report.Artifacts.ExcelReportPath</span></div>
                    </div>
                </div>

                <div class="mt-5 space-y-3 rounded-3xl border border-slate-200 bg-white p-4">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Performance Telemetry</div>
                            <div class="mt-1 text-sm text-slate-600">Measured stage duration, throughput, and worker usage for the current run.</div>
                        </div>
                        <span class="gw-badge bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200">@PerformanceStages.Count stage(s)</span>
                    </div>

                    <div class="grid gap-3 sm:grid-cols-3">
                        <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                            <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Total Duration</div>
                            <div class="mt-2 text-lg font-semibold text-slate-900">@FormatDuration(_report.Summary.TotalDurationMs)</div>
                        </div>
                        <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                            <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Peak Workers</div>
                            <div class="mt-2 text-lg font-semibold text-slate-900">@_report.Summary.PeakConcurrency</div>
                        </div>
                        <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                            <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Fastest Stage</div>
                            <div class="mt-2 text-sm font-semibold text-slate-900">@GetFastestStageLabel()</div>
                        </div>
                    </div>

                    @if (PerformanceStages.Count == 0)
                    {
                        <div class="rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-500">
                            No stage telemetry was found in this execution summary.
                        </div>
                    }
                    else
                    {
                        <ul class="space-y-2">
                            @foreach (var stage in PerformanceStages)
                            {
                                <li class="rounded-2xl border border-slate-200 bg-slate-50/80 px-4 py-3">
                                    <div class="flex flex-wrap items-start justify-between gap-3">
                                        <div>
                                            <div class="text-sm font-semibold text-slate-900">@stage.StageName</div>
                                            <div class="mt-1 text-xs text-slate-500">@stage.ItemCount item(s) processed</div>
                                        </div>
                                        <div class="text-right text-xs text-slate-500">
                                            <div>@FormatDuration(stage.DurationMs)</div>
                                            <div class="mt-1">@FormatThroughput(stage.ItemsPerSecond)</div>
                                            <div class="mt-1">@stage.Concurrency worker(s)</div>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            }
            else
            {
                <div class="gw-empty mt-5">
                    <span class="material-symbols-outlined text-[28px] text-slate-400">shield_lock</span>
                    <div>
                        <h3 class="text-base font-semibold text-slate-900">No execution yet</h3>
                        <p class="mt-2 text-sm leading-6 text-slate-500">
                            The first run will populate the dashboard, result table, inspector, and report artifacts from the same execution.
                        </p>
                    </div>
                </div>
            }

            <div class="mt-5 space-y-3 rounded-3xl border border-slate-200 bg-white p-4">
                <div class="flex items-center justify-between gap-3">
                    <div>
                        <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Execution History</div>
                        <div class="mt-1 text-sm text-slate-600">Recent runs under the current output root.</div>
                    </div>
                    <span class="gw-badge bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200">@_history.Count run(s)</span>
                </div>

                @if (_history.Count == 0)
                {
                    <div class="rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-500">
                        No stored executions were found yet for this output root.
                    </div>
                }
                else
                {
                    <ul class="space-y-2">
                        @foreach (var entry in _history)
                        {
                            <li class="@(string.Equals(entry.ExecutionId, SelectedHistoryExecutionId, StringComparison.OrdinalIgnoreCase)
                                    ? "rounded-2xl border border-blue-300 bg-blue-50/70 px-4 py-3 shadow-sm ring-1 ring-inset ring-blue-100"
                                    : "rounded-2xl border border-slate-200 bg-slate-50/80 px-4 py-3")"
                                data-guardian-history-selected="@(string.Equals(entry.ExecutionId, SelectedHistoryExecutionId, StringComparison.OrdinalIgnoreCase) ? "true" : "false")"
                                @onclick="() => SelectHistoryEntry(entry.ExecutionId)">
                                <div class="flex flex-wrap items-start justify-between gap-3">
                                    <div>
                                        <div class="text-sm font-semibold text-slate-900">@entry.ReportTitle</div>
                                        <div class="mt-1 text-xs text-slate-500">@entry.CompletedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                                        <div class="mt-2 font-mono text-[11px] text-slate-500">@entry.ExecutionId</div>
                                    </div>
                                    <div class="flex flex-wrap items-center justify-end gap-2">
                                        <button type="button" class="gw-button-secondary" @onclick='() => LoadHistoryAsync(entry.JsonResultPath)'>
                                            <span class="material-symbols-outlined text-[18px]">restore_page</span>
                                            Load
                                        </button>
                                        <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(entry.HtmlReportPath)' disabled="@(!CanOpenFile(entry.HtmlReportPath))">
                                            <span class="material-symbols-outlined text-[18px]">web</span>
                                            HTML
                                        </button>
                                        <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(entry.ExcelReportPath)' disabled="@(!CanOpenFile(entry.ExcelReportPath))">
                                            <span class="material-symbols-outlined text-[18px]">table_view</span>
                                            Excel
                                        </button>
                                        <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(entry.JsonResultPath)' disabled="@(!CanOpenFile(entry.JsonResultPath))">
                                            <span class="material-symbols-outlined text-[18px]">data_object</span>
                                            JSON
                                        </button>
                                        <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(entry.LogPath)' disabled="@(!CanOpenFile(entry.LogPath))">
                                            <span class="material-symbols-outlined text-[18px]">article</span>
                                            Log
                                        </button>
                                        <button type="button" class="gw-button-secondary" @onclick='() => OpenPathAsync(entry.OutputDirectory)' disabled="@(!CanOpenDirectory(entry.OutputDirectory))">
                                            <span class="material-symbols-outlined text-[18px]">folder_open</span>
                                            Output
                                        </button>
                                        @if (string.Equals(_pendingDeleteExecutionId, entry.ExecutionId, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <button type="button" class="gw-button-secondary border-red-200 text-red-700" @onclick='() => DeleteHistoryAsync(entry)'>
                                                <span class="material-symbols-outlined text-[18px]">delete_forever</span>
                                                Confirm delete
                                            </button>
                                            <button type="button" class="gw-button-secondary" @onclick="CancelDeleteHistory">
                                                <span class="material-symbols-outlined text-[18px]">close</span>
                                                Cancel
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button" class="gw-button-secondary" @onclick='() => ArmDeleteHistory(entry.ExecutionId)'>
                                                <span class="material-symbols-outlined text-[18px]">delete</span>
                                                Delete
                                            </button>
                                        }
                                    </div>
                                </div>
                                <div class="mt-3 flex flex-wrap gap-2">
                                    @foreach (var status in entry.StatusCounts.OrderByDescending(pair => pair.Value).ThenBy(pair => pair.Key, StringComparer.OrdinalIgnoreCase).Take(3))
                                    {
                                        <span class="gw-badge bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200">@($"{status.Key} {status.Value}")</span>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
        </section>
    </div>

    <section class="gw-home-workspace grid min-h-[32rem] gap-4 xl:min-h-[36rem] xl:flex-1 xl:grid-cols-[minmax(0,1.25fr)_minmax(20rem,0.95fr)] 2xl:grid-cols-guardian">
        <div class="@CompactResultsPanelClass">
            <div class="gw-home-results-toolbar border-b border-slate-200 px-5 py-4">
                <div class="gw-home-results-header flex flex-col gap-3 xl:flex-row xl:items-start xl:justify-between">
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-400">Review Queue</p>
                        <h2 class="mt-1 text-xl font-semibold tracking-[-0.03em] text-slate-950">Comparison results</h2>
                    </div>

                    <div class="gw-home-compact-switch xl:hidden">
                        <button type="button" class="@CompactQueueToggleClass" @onclick="ShowCompactQueue">
                            <span class="material-symbols-outlined text-[18px]">list_alt</span>
                            Queue
                        </button>
                        <button type="button" class="@CompactDetailsToggleClass" @onclick="ShowCompactInspector" disabled="@(!CanToggleCompactInspector)">
                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                            Details
                        </button>
                    </div>

                    <div class="gw-home-results-controls flex flex-col gap-3 xl:min-w-[20rem] xl:max-w-[44rem] xl:flex-1">
                        @if (HasReport)
                        {
                            <div class="gw-home-bulk-actions gw-toolbar-cluster xl:justify-end">
                                <button type="button" class="gw-button-secondary" @onclick="SelectAllVisibleItems" disabled="@(FilteredItems.Count == 0)">
                                    <span class="material-symbols-outlined text-[18px]">select_all</span>
                                    Select visible
                                </button>
                                <button type="button" class="gw-button-secondary" @onclick="SelectVisibleReviewItems" disabled="@(FilteredItems.Count == 0)">
                                    <span class="material-symbols-outlined text-[18px]">rule</span>
                                    Select review set
                                </button>
                                <button type="button" class="gw-button-secondary" @onclick='() => OpenSelectedArtifactsAsync(isCurrent: true)' disabled="@(!CanBulkOpenCurrent)">
                                    <span class="material-symbols-outlined text-[18px]">folder_open</span>
                                    Open selected current
                                </button>
                                <button type="button" class="gw-button-secondary" @onclick='() => OpenSelectedArtifactsAsync(isCurrent: false)' disabled="@(!CanBulkOpenPatch)">
                                    <span class="material-symbols-outlined text-[18px]">folder_open</span>
                                    Open selected patch
                                </button>
                                <button type="button" class="gw-button-secondary" @onclick="ClearBulkSelection" disabled="@(_bulkSelectedPaths.Count == 0)">
                                    <span class="material-symbols-outlined text-[18px]">deselect</span>
                                    Clear (@_bulkSelectedPaths.Count)
                                </button>
                            </div>

                            <details class="gw-home-bulk-drawer">
                                <summary class="gw-button-secondary">
                                    <span class="material-symbols-outlined text-[18px]">tune</span>
                                    Bulk actions
                                    @if (_bulkSelectedPaths.Count > 0)
                                    {
                                        <span class="gw-badge bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200">@_bulkSelectedPaths.Count</span>
                                    }
                                </summary>
                                <div class="gw-home-bulk-drawer-panel">
                                    <button type="button" class="gw-button-secondary" @onclick="SelectAllVisibleItems" disabled="@(FilteredItems.Count == 0)">
                                        <span class="material-symbols-outlined text-[18px]">select_all</span>
                                        Select visible
                                    </button>
                                    <button type="button" class="gw-button-secondary" @onclick="SelectVisibleReviewItems" disabled="@(FilteredItems.Count == 0)">
                                        <span class="material-symbols-outlined text-[18px]">rule</span>
                                        Select review set
                                    </button>
                                    <button type="button" class="gw-button-secondary" @onclick='() => OpenSelectedArtifactsAsync(isCurrent: true)' disabled="@(!CanBulkOpenCurrent)">
                                        <span class="material-symbols-outlined text-[18px]">folder_open</span>
                                        Open selected current
                                    </button>
                                    <button type="button" class="gw-button-secondary" @onclick='() => OpenSelectedArtifactsAsync(isCurrent: false)' disabled="@(!CanBulkOpenPatch)">
                                        <span class="material-symbols-outlined text-[18px]">folder_open</span>
                                        Open selected patch
                                    </button>
                                    <button type="button" class="gw-button-secondary" @onclick="ClearBulkSelection" disabled="@(_bulkSelectedPaths.Count == 0)">
                                        <span class="material-symbols-outlined text-[18px]">deselect</span>
                                        Clear (@_bulkSelectedPaths.Count)
                                    </button>
                                </div>
                            </details>
                        }

                        <div class="gw-toolbar-cluster xl:justify-end">
                            @foreach (var filter in Filters)
                            {
                                <button type="button" class="@(filter == _selectedFilter ? "gw-chip-active" : "gw-chip")" @onclick="() => SelectFilter(filter)">
                                    @FilterLabel(filter)
                                </button>
                            }
                        </div>

                        <div class="w-full xl:ml-auto xl:max-w-[320px]">
                            <input id="guardian-result-search" @bind="_searchText" @bind:event="oninput" class="gw-input w-full min-w-0" placeholder="Search path, rule, status" />
                        </div>
                    </div>
                </div>
            </div>

            @if (!HasReport)
            {
                <div class="m-5 gw-empty">
                    <span class="material-symbols-outlined text-[28px] text-slate-400">list_alt</span>
                    <div>
                        <h3 class="text-base font-semibold text-slate-900">Results will appear here</h3>
                        <p class="mt-2 text-sm leading-6 text-slate-500">
                            Run the compare workflow to inspect per-file status, severity, rule binding, and summary messages.
                        </p>
                    </div>
                </div>
            }
            else
            {
                <div class="gw-home-results-scroll min-h-0 overflow-auto px-2 pb-2">
                    <table class="gw-table">
                        <thead class="sticky top-0 bg-white/95 backdrop-blur">
                            <tr class="text-left text-xs uppercase tracking-[0.2em] text-slate-400">
                                <th class="w-12 px-3 py-3">Sel</th>
                                <th class="px-3 py-3">Path</th>
                                <th class="px-3 py-3">Status</th>
                                <th class="px-3 py-3">Severity</th>
                                <th class="gw-home-col-secondary px-3 py-3">Type</th>
                                <th class="gw-home-col-secondary px-3 py-3">Rule</th>
                                <th class="px-3 py-3">Summary</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in FilteredItems)
                            {
                                <tr class="@(row.RelativePath == SelectedRelativePath ? "gw-row-active" : "gw-row")"
                                    data-guardian-selected="@(row.RelativePath == SelectedRelativePath ? "true" : "false")"
                                    @onclick="() => SelectItem(row.RelativePath)">
                                    <td class="px-3 py-3" @onclick:stopPropagation="true">
                                        <input type="checkbox"
                                               class="h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-400"
                                               checked="@IsBulkSelected(row.RelativePath)"
                                               @onchange="args => SetBulkSelection(row.RelativePath, args.Value as bool? ?? false)" />
                                    </td>
                                    <td class="px-3 py-3">
                                        <div class="font-mono text-xs text-slate-900">@row.RelativePath</div>
                                        <div class="gw-home-row-meta">
                                            <span class="rounded-full bg-slate-100 px-2 py-1 text-[11px] font-semibold uppercase tracking-wide text-slate-500">@row.FileType</span>
                                            <span class="truncate font-mono text-[11px] text-slate-500">@row.RuleId</span>
                                        </div>
                                    </td>
                                    <td class="px-3 py-3">
                                        <StatusBadge Text="@row.Status.ToString()" BadgeClass="@GetStatusBadgeClass(row.Status)" />
                                    </td>
                                    <td class="px-3 py-3">
                                        <StatusBadge Text="@row.Severity.ToString()" BadgeClass="@GetSeverityBadgeClass(row.Severity)" />
                                    </td>
                                    <td class="gw-home-col-secondary px-3 py-3 text-xs font-semibold uppercase tracking-wide text-slate-500">@row.FileType</td>
                                    <td class="gw-home-col-secondary px-3 py-3 font-mono text-xs text-slate-600">@row.RuleId</td>
                                    <td class="px-3 py-3 text-sm text-slate-600">
                                        <div class="gw-home-summary-text">@row.Summary</div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <GuardianInspectorPanel Item="SelectedItem"
                               CurrentArtifactPath="SelectedCurrentArtifactPath"
                               PatchArtifactPath="SelectedPatchArtifactPath"
                               CanOpenCurrentArtifact="CanOpenSelectedCurrentArtifact"
                               CanOpenPatchArtifact="CanOpenSelectedPatchArtifact"
                               CompactMode="true"
                               OnOpenPath="OpenPathAsync"
                               OnClose="HideCompactInspector"
                               ShowCloseButton="true"
                               PanelClass="@CompactInspectorPanelClass" />

        <GuardianInspectorPanel Item="SelectedItem"
                               CurrentArtifactPath="SelectedCurrentArtifactPath"
                               PatchArtifactPath="SelectedPatchArtifactPath"
                               CanOpenCurrentArtifact="CanOpenSelectedCurrentArtifact"
                               CanOpenPatchArtifact="CanOpenSelectedPatchArtifact"
                               CompactMode="false"
                               OnOpenPath="OpenPathAsync"
                               PanelClass="gw-home-inspector hidden gw-panel min-h-[24rem] flex-col overflow-hidden xl:flex xl:min-h-0" />
    </section>
</div>

@if (_showShortcutOverlay)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/55 px-4 py-8" @onclick="HideShortcutOverlay">
        <section class="w-full max-w-3xl rounded-[2rem] border border-slate-200 bg-white shadow-2xl" @onclick:stopPropagation="true">
            <div class="flex items-start justify-between gap-4 border-b border-slate-200 px-6 py-5">
                <div>
                    <div class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Shortcut Help</div>
                    <h3 class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-slate-950">Guardian keyboard controls</h3>
                    <p class="mt-2 text-sm leading-6 text-slate-600">
                        Use these shortcuts to run inspections and move faster through the review workflow. Press <span class="font-mono text-xs text-slate-700">Esc</span> to close this panel.
                    </p>
                </div>

                <button type="button" class="gw-button-secondary" @onclick="HideShortcutOverlay">
                    <span class="material-symbols-outlined text-[18px]">close</span>
                    Close
                </button>
            </div>

            <div class="grid gap-4 px-6 py-5 md:grid-cols-2">
                @foreach (var shortcut in ShortcutEntries)
                {
                    <article class="rounded-3xl border border-slate-200 bg-slate-50/80 p-4">
                        <div class="flex flex-wrap items-center gap-2">
                            @foreach (var key in shortcut.Keys)
                            {
                                <span class="rounded-xl border border-slate-200 bg-white px-3 py-1 font-mono text-xs text-slate-700 shadow-sm">@key</span>
                            }
                        </div>
                        <div class="mt-4 text-base font-semibold text-slate-900">@shortcut.Title</div>
                        <p class="mt-2 text-sm leading-6 text-slate-600">@shortcut.Description</p>
                    </article>
                }
            </div>
        </section>
    </div>
}

