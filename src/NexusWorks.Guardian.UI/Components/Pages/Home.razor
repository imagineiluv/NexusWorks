@page "/"
@using System.ComponentModel.DataAnnotations
@using Microsoft.Maui.ApplicationModel
@using Microsoft.Maui.Storage
@inject IPathSelectionService PathSelector
@inject GuardianWorkbenchService Workbench

<div class="flex min-h-0 flex-1 flex-col gap-6 overflow-hidden">
    <section class="grid gap-4 xl:grid-cols-[1.08fr_0.92fr]">
        <div class="gw-panel p-5 lg:p-6">
            <div class="flex flex-wrap items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-400">Execution Setup</p>
                    <h2 class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-slate-950">Run a Guardian inspection</h2>
                    <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">
                        Enter current root, patch root, baseline workbook, and output root. The run generates HTML and Excel artifacts and hydrates the in-app review console.
                    </p>
                </div>

                <span class="gw-badge bg-blue-50 text-blue-700 ring-1 ring-inset ring-blue-200">Phase 3 UI</span>
            </div>

            <EditForm Model="_runForm" OnValidSubmit="RunCompareAsync" class="mt-6 grid gap-4">
                <DataAnnotationsValidator />

                <div class="grid gap-4 md:grid-cols-2">
                    <div class="space-y-2 md:col-span-2">
                        <label class="gw-label" for="reportTitle">Report title</label>
                        <InputText id="reportTitle" @bind-Value="_runForm.ReportTitle" class="gw-input" />
                        <ValidationMessage For="@(() => _runForm.ReportTitle)" class="gw-validation" />
                    </div>

                    <div class="space-y-2">
                        <label class="gw-label" for="currentRoot">Current root</label>
                        <div class="flex gap-2">
                            <InputText id="currentRoot" @bind-Value="_runForm.CurrentRootPath" class="gw-input flex-1" />
                            <button type="button" class="gw-button-secondary shrink-0" @onclick='() => BrowseFolderAsync(PathField.CurrentRoot)' disabled="@_isRunning">Browse</button>
                            <span class="gw-badge @CurrentRootBadge.BadgeClass">@CurrentRootBadge.Label</span>
                        </div>
                        <ValidationMessage For="@(() => _runForm.CurrentRootPath)" class="gw-validation" />
                        @if (_recentCurrentRoots.Count > 0)
                        {
                            <select class="gw-input text-sm" @onchange="eventArgs => ApplyRecentPathAsync(PathField.CurrentRoot, eventArgs.Value?.ToString())">
                                <option value="">Recent current roots</option>
                                @foreach (var path in _recentCurrentRoots)
                                {
                                    <option value="@path">@path</option>
                                }
                            </select>
                        }
                    </div>

                    <div class="space-y-2">
                        <label class="gw-label" for="patchRoot">Patch root</label>
                        <div class="flex gap-2">
                            <InputText id="patchRoot" @bind-Value="_runForm.PatchRootPath" class="gw-input flex-1" />
                            <button type="button" class="gw-button-secondary shrink-0" @onclick='() => BrowseFolderAsync(PathField.PatchRoot)' disabled="@_isRunning">Browse</button>
                            <span class="gw-badge @PatchRootBadge.BadgeClass">@PatchRootBadge.Label</span>
                        </div>
                        <ValidationMessage For="@(() => _runForm.PatchRootPath)" class="gw-validation" />
                        @if (_recentPatchRoots.Count > 0)
                        {
                            <select class="gw-input text-sm" @onchange="eventArgs => ApplyRecentPathAsync(PathField.PatchRoot, eventArgs.Value?.ToString())">
                                <option value="">Recent patch roots</option>
                                @foreach (var path in _recentPatchRoots)
                                {
                                    <option value="@path">@path</option>
                                }
                            </select>
                        }
                    </div>

                    <div class="space-y-2 md:col-span-2">
                        <label class="gw-label" for="baselinePath">Baseline workbook</label>
                        <div class="flex gap-2">
                            <InputText id="baselinePath" @bind-Value="_runForm.BaselinePath" @bind-Value:after="OnBaselinePathChangedAsync" class="gw-input flex-1" />
                            <button type="button" class="gw-button-secondary shrink-0" @onclick="BrowseBaselineAsync" disabled="@_isRunning">Browse</button>
                            <span class="gw-badge @BaselinePathBadge.BadgeClass">@BaselinePathBadge.Label</span>
                        </div>
                        <ValidationMessage For="@(() => _runForm.BaselinePath)" class="gw-validation" />
                        @if (_recentBaselinePaths.Count > 0)
                        {
                            <select class="gw-input text-sm" @onchange="eventArgs => ApplyRecentPathAsync(PathField.BaselinePath, eventArgs.Value?.ToString())">
                                <option value="">Recent baseline files</option>
                                @foreach (var path in _recentBaselinePaths)
                                {
                                    <option value="@path">@path</option>
                                }
                            </select>
                        }
                    </div>

                    <div class="space-y-2 md:col-span-2">
                        <label class="gw-label" for="outputRoot">Output root</label>
                        <div class="flex gap-2">
                            <InputText id="outputRoot" @bind-Value="_runForm.OutputRootPath" @bind-Value:after="OnOutputRootChangedAsync" class="gw-input flex-1" />
                            <button type="button" class="gw-button-secondary shrink-0" @onclick='() => BrowseFolderAsync(PathField.OutputRoot)' disabled="@_isRunning">Browse</button>
                            <span class="gw-badge @OutputRootBadge.BadgeClass">@OutputRootBadge.Label</span>
                        </div>
                        <ValidationMessage For="@(() => _runForm.OutputRootPath)" class="gw-validation" />
                        @if (_recentOutputRoots.Count > 0)
                        {
                            <select class="gw-input text-sm" @onchange="eventArgs => ApplyRecentPathAsync(PathField.OutputRoot, eventArgs.Value?.ToString())">
                                <option value="">Recent output roots</option>
                                @foreach (var path in _recentOutputRoots)
                                {
                                    <option value="@path">@path</option>
                                }
                            </select>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                        @_errorMessage
                    </div>
                }

                @if (_baselinePreview is not null || !string.IsNullOrWhiteSpace(_baselinePreviewError))
                {
                    <div class="rounded-3xl border border-slate-200 bg-slate-50/80 p-4">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Baseline Preview</div>
                                <div class="mt-1 text-sm text-slate-600">Quick validation and rule summary for the selected workbook.</div>
                            </div>
                            <span class="gw-badge @(_baselinePreview is null ? "bg-red-100 text-red-700 ring-1 ring-inset ring-red-200" : "bg-emerald-100 text-emerald-700 ring-1 ring-inset ring-emerald-200")">
                                @(_baselinePreview is null ? "Invalid" : "Loaded")
                            </span>
                        </div>

                        @if (_baselinePreview is not null)
                        {
                            <div class="mt-4 grid gap-3 sm:grid-cols-3">
                                <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3">
                                    <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Rules</div>
                                    <div class="mt-2 text-lg font-semibold text-slate-900">@_baselinePreview.TotalRuleCount</div>
                                </div>
                                <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3">
                                    <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Required</div>
                                    <div class="mt-2 text-lg font-semibold text-slate-900">@_baselinePreview.RequiredRuleCount</div>
                                </div>
                                <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3">
                                    <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Excluded</div>
                                    <div class="mt-2 text-lg font-semibold text-slate-900">@_baselinePreview.ExcludedRuleCount</div>
                                </div>
                            </div>

                            <div class="mt-4 flex flex-wrap gap-2">
                                @foreach (var pair in _baselinePreview.FileTypeCounts)
                                {
                                    <span class="gw-badge bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200">@($"{pair.Key} {pair.Value}")</span>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="mt-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">@_baselinePreviewError</div>
                        }
                    </div>
                }

                <div class="flex flex-wrap items-center gap-3">
                    <button type="submit" class="gw-button" disabled="@_isRunning">
                        <span class="material-symbols-outlined text-[18px]">play_arrow</span>
                        @(_isRunning ? "Running compare" : "Run compare")
                    </button>
                    <button type="button" class="gw-button-secondary" @onclick="RerunAsync" disabled="@(!HasReport || _isRunning)">
                        <span class="material-symbols-outlined text-[18px]">refresh</span>
                        Rerun
                    </button>
                    <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(_report?.Artifacts.HtmlReportPath)' disabled="@(!HasReport)">
                        <span class="material-symbols-outlined text-[18px]">web</span>
                        Open HTML
                    </button>
                    <button type="button" class="gw-button-secondary" @onclick='() => OpenFileAsync(_report?.Artifacts.ExcelReportPath)' disabled="@(!HasReport)">
                        <span class="material-symbols-outlined text-[18px]">table_view</span>
                        Open Excel
                    </button>
                    <button type="button" class="gw-button-secondary" @onclick="RefreshHistoryAsync" disabled="@_isRunning">
                        <span class="material-symbols-outlined text-[18px]">history</span>
                        Refresh history
                    </button>
                </div>
            </EditForm>
        </div>

        <div class="gw-panel p-5 lg:p-6">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-400">Run Summary</p>
                    <h2 class="mt-2 text-xl font-semibold tracking-[-0.03em] text-slate-950">Execution health</h2>
                </div>
                @if (HasReport)
                {
                    <span class="gw-badge bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200">Artifacts Ready</span>
                }
            </div>

            @if (HasReport)
            {
                <div class="mt-5 grid gap-4 sm:grid-cols-2 xl:grid-cols-2">
                    @foreach (var card in SummaryCards)
                    {
                        <article class="gw-kpi-card">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <div class="text-sm font-medium text-slate-500">@card.Title</div>
                                    <div class="mt-3 text-3xl font-semibold tracking-[-0.05em] text-slate-950">@card.Value</div>
                                </div>
                                <span class="gw-badge @card.BadgeClass">@card.Badge</span>
                            </div>
                            <p class="mt-3 text-xs leading-5 text-slate-500">@card.Note</p>
                        </article>
                    }
                </div>

                <div class="mt-5 space-y-3 rounded-3xl border border-slate-200 bg-slate-50/90 p-4">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                            <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Execution ID</div>
                            <div class="gw-code mt-2">@_report!.Summary.ExecutionId</div>
                        </div>
                        <div class="text-right text-sm text-slate-500">
                            <div>Completed</div>
                            <div class="mt-1 font-semibold text-slate-700">@_report.Summary.CompletedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                        </div>
                    </div>
                    <div class="space-y-2 text-sm text-slate-600">
                        <div><span class="font-semibold text-slate-800">Output:</span> <span class="font-mono text-xs">@_report.Artifacts.OutputDirectory</span></div>
                        <div><span class="font-semibold text-slate-800">HTML:</span> <span class="font-mono text-xs">@_report.Artifacts.HtmlReportPath</span></div>
                        <div><span class="font-semibold text-slate-800">Excel:</span> <span class="font-mono text-xs">@_report.Artifacts.ExcelReportPath</span></div>
                    </div>
                </div>

                <div class="mt-5 space-y-3 rounded-3xl border border-slate-200 bg-white p-4">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Performance Telemetry</div>
                            <div class="mt-1 text-sm text-slate-600">Measured stage duration, throughput, and worker usage for the current run.</div>
                        </div>
                        <span class="gw-badge bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200">@PerformanceStages.Count stage(s)</span>
                    </div>

                    <div class="grid gap-3 sm:grid-cols-3">
                        <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                            <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Total Duration</div>
                            <div class="mt-2 text-lg font-semibold text-slate-900">@FormatDuration(_report.Summary.TotalDurationMs)</div>
                        </div>
                        <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                            <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Peak Workers</div>
                            <div class="mt-2 text-lg font-semibold text-slate-900">@_report.Summary.PeakConcurrency</div>
                        </div>
                        <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                            <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Fastest Stage</div>
                            <div class="mt-2 text-sm font-semibold text-slate-900">@GetFastestStageLabel()</div>
                        </div>
                    </div>

                    @if (PerformanceStages.Count == 0)
                    {
                        <div class="rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-500">
                            No stage telemetry was found in this execution summary.
                        </div>
                    }
                    else
                    {
                        <ul class="space-y-2">
                            @foreach (var stage in PerformanceStages)
                            {
                                <li class="rounded-2xl border border-slate-200 bg-slate-50/80 px-4 py-3">
                                    <div class="flex flex-wrap items-start justify-between gap-3">
                                        <div>
                                            <div class="text-sm font-semibold text-slate-900">@stage.StageName</div>
                                            <div class="mt-1 text-xs text-slate-500">@stage.ItemCount item(s) processed</div>
                                        </div>
                                        <div class="text-right text-xs text-slate-500">
                                            <div>@FormatDuration(stage.DurationMs)</div>
                                            <div class="mt-1">@FormatThroughput(stage.ItemsPerSecond)</div>
                                            <div class="mt-1">@stage.Concurrency worker(s)</div>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            }
            else
            {
                <div class="gw-empty mt-5">
                    <span class="material-symbols-outlined text-[28px] text-slate-400">shield_lock</span>
                    <div>
                        <h3 class="text-base font-semibold text-slate-900">No execution yet</h3>
                        <p class="mt-2 text-sm leading-6 text-slate-500">
                            The first run will populate the dashboard, result table, inspector, and report artifacts from the same execution.
                        </p>
                    </div>
                </div>
            }

            <div class="mt-5 space-y-3 rounded-3xl border border-slate-200 bg-white p-4">
                <div class="flex items-center justify-between gap-3">
                    <div>
                        <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Execution History</div>
                        <div class="mt-1 text-sm text-slate-600">Recent runs under the current output root.</div>
                    </div>
                    <span class="gw-badge bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200">@_history.Count run(s)</span>
                </div>

                @if (_history.Count == 0)
                {
                    <div class="rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-500">
                        No stored executions were found yet for this output root.
                    </div>
                }
                else
                {
                    <ul class="space-y-2">
                        @foreach (var entry in _history)
                        {
                            <li class="rounded-2xl border border-slate-200 bg-slate-50/80 px-4 py-3">
                                <div class="flex flex-wrap items-start justify-between gap-3">
                                    <div>
                                        <div class="text-sm font-semibold text-slate-900">@entry.ReportTitle</div>
                                        <div class="mt-1 text-xs text-slate-500">@entry.CompletedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                                        <div class="mt-2 font-mono text-[11px] text-slate-500">@entry.ExecutionId</div>
                                    </div>
                                    <button type="button" class="gw-button-secondary" @onclick='() => LoadHistoryAsync(entry.JsonResultPath)'>
                                        <span class="material-symbols-outlined text-[18px]">restore_page</span>
                                        Load
                                    </button>
                                </div>
                                <div class="mt-3 flex flex-wrap gap-2">
                                    @foreach (var status in entry.StatusCounts.OrderByDescending(pair => pair.Value).ThenBy(pair => pair.Key, StringComparer.OrdinalIgnoreCase).Take(3))
                                    {
                                        <span class="gw-badge bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200">@($"{status.Key} {status.Value}")</span>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </section>

    <section class="grid min-h-0 flex-1 gap-4 xl:grid-cols-guardian">
        <div class="gw-panel flex min-h-0 flex-col overflow-hidden">
            <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-200 px-5 py-4">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-400">Review Queue</p>
                    <h2 class="mt-1 text-xl font-semibold tracking-[-0.03em] text-slate-950">Comparison results</h2>
                </div>

                <div class="flex flex-1 flex-wrap items-center justify-end gap-2">
                    @foreach (var filter in Filters)
                    {
                        <button type="button" class="@(filter == _selectedFilter ? "gw-chip-active" : "gw-chip")" @onclick="() => SelectFilter(filter)">
                            @FilterLabel(filter)
                        </button>
                    }
                    <input @bind="_searchText" @bind:event="oninput" class="gw-input w-full min-w-[220px] max-w-[320px]" placeholder="Search path, rule, status" />
                </div>
            </div>

            @if (!HasReport)
            {
                <div class="m-5 gw-empty">
                    <span class="material-symbols-outlined text-[28px] text-slate-400">list_alt</span>
                    <div>
                        <h3 class="text-base font-semibold text-slate-900">Results will appear here</h3>
                        <p class="mt-2 text-sm leading-6 text-slate-500">
                            Run the compare workflow to inspect per-file status, severity, rule binding, and summary messages.
                        </p>
                    </div>
                </div>
            }
            else
            {
                <div class="min-h-0 overflow-auto px-2 pb-2">
                    <table class="gw-table">
                        <thead class="sticky top-0 bg-white/95 backdrop-blur">
                            <tr class="text-left text-xs uppercase tracking-[0.2em] text-slate-400">
                                <th class="px-3 py-3">Path</th>
                                <th class="px-3 py-3">Status</th>
                                <th class="px-3 py-3">Severity</th>
                                <th class="px-3 py-3">Type</th>
                                <th class="px-3 py-3">Rule</th>
                                <th class="px-3 py-3">Summary</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in FilteredItems)
                            {
                                <tr class="@(row.RelativePath == SelectedRelativePath ? "gw-row-active" : "gw-row")" @onclick="() => SelectItem(row.RelativePath)">
                                    <td class="px-3 py-3">
                                        <div class="font-mono text-xs text-slate-900">@row.RelativePath</div>
                                    </td>
                                    <td class="px-3 py-3">
                                        <span class="gw-badge @GetStatusBadgeClass(row.Status)">@row.Status</span>
                                    </td>
                                    <td class="px-3 py-3">
                                        <span class="gw-badge @GetSeverityBadgeClass(row.Severity)">@row.Severity</span>
                                    </td>
                                    <td class="px-3 py-3 text-xs font-semibold uppercase tracking-wide text-slate-500">@row.FileType</td>
                                    <td class="px-3 py-3 font-mono text-xs text-slate-600">@row.RuleId</td>
                                    <td class="px-3 py-3 text-sm text-slate-600">@row.Summary</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <aside class="gw-panel flex min-h-0 flex-col overflow-hidden">
            <div class="border-b border-slate-200 px-5 py-4">
                <div class="flex items-center justify-between gap-3">
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-400">Inspector</p>
                        <h2 class="mt-1 text-xl font-semibold tracking-[-0.03em] text-slate-950">@(SelectedItem?.RelativePath ?? "Awaiting selection")</h2>
                    </div>
                    @if (SelectedItem is not null)
                    {
                        <span class="gw-badge @GetStatusBadgeClass(SelectedItem.Status)">@SelectedItem.Status</span>
                    }
                </div>
            </div>

            @if (SelectedItem is null)
            {
                <div class="m-5 gw-empty">
                    <span class="material-symbols-outlined text-[28px] text-slate-400">manage_search</span>
                    <div>
                        <h3 class="text-base font-semibold text-slate-900">No item selected</h3>
                        <p class="mt-2 text-sm leading-6 text-slate-500">
                            Select a comparison row to inspect compare mode, hashes, messages, and JAR/XML/YAML deltas.
                        </p>
                    </div>
                </div>
            }
            else
            {
                <div class="min-h-0 flex-1 space-y-5 overflow-auto p-5">
                    <section class="space-y-3">
                        <div class="flex items-center gap-2 text-sm font-semibold text-slate-700">
                            <span class="material-symbols-outlined text-[18px] text-slate-400">rule_settings</span>
                            Applied Rule
                        </div>
                        <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
                            <div class="grid gap-3 md:grid-cols-2">
                                <div>
                                    <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Rule ID</div>
                                    <div class="mt-2 font-mono text-sm text-slate-900">@SelectedItem.RuleId</div>
                                </div>
                                <div>
                                    <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Compare Mode</div>
                                    <div class="mt-2 text-sm text-slate-700">@SelectedItem.CompareMode</div>
                                </div>
                                <div>
                                    <div class="text-xs uppercase tracking-[0.18em] text-slate-400">File Type</div>
                                    <div class="mt-2 text-sm text-slate-700">@SelectedItem.FileType</div>
                                </div>
                                <div>
                                    <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Severity</div>
                                    <div class="mt-2 text-sm text-slate-700">@SelectedItem.Severity</div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="space-y-3">
                        <div class="flex items-center gap-2 text-sm font-semibold text-slate-700">
                            <span class="material-symbols-outlined text-[18px] text-slate-400">difference</span>
                            Hash Compare
                        </div>
                        <div class="grid gap-3 rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
                            <div>
                                <div class="mb-2 text-xs uppercase tracking-[0.18em] text-slate-400">Current</div>
                                <div class="gw-code">@(SelectedItem.CurrentHash ?? "-")</div>
                            </div>
                            <div>
                                <div class="mb-2 text-xs uppercase tracking-[0.18em] text-slate-400">Patch</div>
                                <div class="gw-code">@(SelectedItem.PatchHash ?? "-")</div>
                            </div>
                        </div>
                    </section>

                    <section class="space-y-3">
                        <div class="flex items-center gap-2 text-sm font-semibold text-slate-700">
                            <span class="material-symbols-outlined text-[18px] text-slate-400">notes</span>
                            Messages
                        </div>
                        <ul class="space-y-2">
                            @foreach (var message in SelectedItem.Messages.DefaultIfEmpty("No additional messages."))
                            {
                                <li class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm leading-6 text-slate-600">@message</li>
                            }
                        </ul>
                    </section>

                    @if (SelectedItem.JarDetail is not null)
                    {
                        <section class="space-y-3">
                            <div class="flex items-center gap-2 text-sm font-semibold text-slate-700">
                                <span class="material-symbols-outlined text-[18px] text-slate-400">view_list</span>
                                JAR Delta
                            </div>
                            <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4 text-sm text-slate-600">
                                <div>Manifest Changed: <span class="font-semibold text-slate-900">@SelectedItem.JarDetail.ManifestChanged</span></div>
                                <div class="mt-2">Class Delta: <span class="font-semibold text-slate-900">+@SelectedItem.JarDetail.AddedClassCount / -@SelectedItem.JarDetail.RemovedClassCount / Δ@SelectedItem.JarDetail.ChangedClassCount</span></div>
                                <div class="mt-3 grid gap-3 md:grid-cols-3">
                                    <div>
                                        <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Added</div>
                                        <ul class="mt-2 space-y-2">
                                            @foreach (var entry in SelectedItem.JarDetail.AddedEntries.DefaultIfEmpty("-"))
                                            {
                                                <li class="rounded-xl border border-slate-200 bg-white px-3 py-2 font-mono text-xs text-slate-700">@entry</li>
                                            }
                                        </ul>
                                    </div>
                                    <div>
                                        <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Removed</div>
                                        <ul class="mt-2 space-y-2">
                                            @foreach (var entry in SelectedItem.JarDetail.RemovedEntries.DefaultIfEmpty("-"))
                                            {
                                                <li class="rounded-xl border border-slate-200 bg-white px-3 py-2 font-mono text-xs text-slate-700">@entry</li>
                                            }
                                        </ul>
                                    </div>
                                    <div>
                                        <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Changed</div>
                                        <ul class="mt-2 space-y-2">
                                            @foreach (var entry in SelectedItem.JarDetail.ChangedEntries.DefaultIfEmpty("-"))
                                            {
                                                <li class="rounded-xl border border-slate-200 bg-white px-3 py-2 font-mono text-xs text-slate-700">@entry</li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                                <div class="mt-4">
                                    <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Package Summary</div>
                                    <ul class="mt-2 space-y-2">
                                        @foreach (var summary in SelectedItem.JarDetail.PackageSummaries.DefaultIfEmpty(new JarPackageChangeSummary("(none)", 0, 0, 0)))
                                        {
                                            <li class="rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs text-slate-700">
                                                <span class="font-mono">@summary.PackageName</span>
                                                <span class="ml-2">+@summary.AddedClassCount / -@summary.RemovedClassCount / Δ@summary.ChangedClassCount</span>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </section>
                    }

                    @if (SelectedItem.XmlDetail is not null)
                    {
                        <section class="space-y-3">
                            <div class="flex items-center gap-2 text-sm font-semibold text-slate-700">
                                <span class="material-symbols-outlined text-[18px] text-slate-400">account_tree</span>
                                XML Delta
                            </div>
                            <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4 text-sm text-slate-600">
                                <div class="grid gap-3 md:grid-cols-3">
                                    <div class="rounded-xl border border-slate-200 bg-white px-3 py-3">
                                        <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Added Nodes</div>
                                        <div class="mt-2 text-lg font-semibold text-slate-900">@SelectedItem.XmlDetail.AddedNodes</div>
                                    </div>
                                    <div class="rounded-xl border border-slate-200 bg-white px-3 py-3">
                                        <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Removed Nodes</div>
                                        <div class="mt-2 text-lg font-semibold text-slate-900">@SelectedItem.XmlDetail.RemovedNodes</div>
                                    </div>
                                    <div class="rounded-xl border border-slate-200 bg-white px-3 py-3">
                                        <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Changed Nodes</div>
                                        <div class="mt-2 text-lg font-semibold text-slate-900">@SelectedItem.XmlDetail.ChangedNodeCount</div>
                                    </div>
                                </div>
                                <ul class="mt-3 space-y-2">
                                    @foreach (var xpath in SelectedItem.XmlDetail.ChangedXPaths.DefaultIfEmpty("-"))
                                    {
                                        <li class="rounded-xl border border-slate-200 bg-white px-3 py-2 font-mono text-xs text-slate-700">@xpath</li>
                                    }
                                </ul>
                                <div class="mt-4">
                                    <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Detailed Changes</div>
                                    <ul class="mt-2 space-y-2">
                                        @foreach (var change in SelectedItem.XmlDetail.Changes.DefaultIfEmpty(new XmlChangeEntry("-", "none", null, null)))
                                        {
                                            <li class="rounded-xl border border-slate-200 bg-white px-3 py-3 text-xs text-slate-700">
                                                <div class="font-semibold uppercase tracking-[0.14em] text-slate-500">@change.ChangeKind</div>
                                                <div class="mt-2 font-mono">@change.Path</div>
                                                <div class="mt-2 text-slate-500">@(change.CurrentValue ?? "-") -> @(change.PatchValue ?? "-")</div>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </section>
                    }

                    @if (SelectedItem.YamlDetail is not null)
                    {
                        <section class="space-y-3">
                            <div class="flex items-center gap-2 text-sm font-semibold text-slate-700">
                                <span class="material-symbols-outlined text-[18px] text-slate-400">data_object</span>
                                YAML Delta
                            </div>
                            <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4 text-sm text-slate-600">
                                <div class="grid gap-3 md:grid-cols-3">
                                    <div class="rounded-xl border border-slate-200 bg-white px-3 py-3">
                                        <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Added Keys</div>
                                        <div class="mt-2 text-lg font-semibold text-slate-900">@SelectedItem.YamlDetail.AddedKeys</div>
                                    </div>
                                    <div class="rounded-xl border border-slate-200 bg-white px-3 py-3">
                                        <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Removed Keys</div>
                                        <div class="mt-2 text-lg font-semibold text-slate-900">@SelectedItem.YamlDetail.RemovedKeys</div>
                                    </div>
                                    <div class="rounded-xl border border-slate-200 bg-white px-3 py-3">
                                        <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Changed Nodes</div>
                                        <div class="mt-2 text-lg font-semibold text-slate-900">@SelectedItem.YamlDetail.ChangedNodeCount</div>
                                    </div>
                                </div>
                                <ul class="mt-3 space-y-2">
                                    @foreach (var path in SelectedItem.YamlDetail.ChangedPaths.DefaultIfEmpty("-"))
                                    {
                                        <li class="rounded-xl border border-slate-200 bg-white px-3 py-2 font-mono text-xs text-slate-700">@path</li>
                                    }
                                </ul>
                            </div>
                        </section>
                    }
                </div>
            }
        </aside>
    </section>
</div>

@code {
    private readonly RunFormModel _runForm = new();
    private ExecutionReport? _report;
    private IReadOnlyList<ExecutionHistoryEntry> _history = Array.Empty<ExecutionHistoryEntry>();
    private IReadOnlyList<string> _recentCurrentRoots = Array.Empty<string>();
    private IReadOnlyList<string> _recentPatchRoots = Array.Empty<string>();
    private IReadOnlyList<string> _recentBaselinePaths = Array.Empty<string>();
    private IReadOnlyList<string> _recentOutputRoots = Array.Empty<string>();
    private BaselinePreviewSummary? _baselinePreview;
    private string? _baselinePreviewError;
    private string? _errorMessage;
    private string _searchText = string.Empty;
    private ResultFilter _selectedFilter = ResultFilter.All;
    private bool _isRunning;
    private string? SelectedRelativePath { get; set; }

    private bool HasReport => _report is not null;
    private PathStatusBadge CurrentRootBadge => EvaluateDirectoryBadge(_runForm.CurrentRootPath);
    private PathStatusBadge PatchRootBadge => EvaluateDirectoryBadge(_runForm.PatchRootPath);
    private PathStatusBadge OutputRootBadge => EvaluateDirectoryBadge(_runForm.OutputRootPath);
    private PathStatusBadge BaselinePathBadge => EvaluateBaselineBadge(_runForm.BaselinePath, _baselinePreviewError);

    private IReadOnlyList<SummaryCard> SummaryCards =>
    [
        new("Files scanned", GetCount("Total"), "Inventory", "bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200", "Total result items in this execution."),
        new("Changed items", GetCount(CompareStatus.Changed.ToString()), "Changed", "bg-amber-100 text-amber-700 ring-1 ring-inset ring-amber-200", "Items with meaningful differences after configured compare rules."),
        new("Critical issues", GetCriticalCount(), "Critical", "bg-red-100 text-red-700 ring-1 ring-inset ring-red-200", "Missing required files and explicit errors block approval."),
        new("Artifacts", HasReport ? "4" : "0", "Ready", "bg-blue-100 text-blue-700 ring-1 ring-inset ring-blue-200", "HTML, Excel, JSON, and execution log are written per run."),
    ];

    private IReadOnlyList<ResultFilter> Filters =>
    [
        ResultFilter.All,
        ResultFilter.Changed,
        ResultFilter.MissingRequired,
        ResultFilter.Error,
        ResultFilter.Ok,
    ];

    private IReadOnlyList<ComparisonItemResult> FilteredItems => _report?.Result.Items
        .Where(MatchesFilter)
        .Where(MatchesSearch)
        .OrderByDescending(GetSeverityWeight)
        .ThenBy(item => item.RelativePath, StringComparer.OrdinalIgnoreCase)
        .ToArray() ?? Array.Empty<ComparisonItemResult>();

    private IReadOnlyList<ExecutionStageMetric> PerformanceStages => _report?.Summary.StageMetrics ?? Array.Empty<ExecutionStageMetric>();

    private ComparisonItemResult? SelectedItem => FilteredItems.FirstOrDefault(item => item.RelativePath == SelectedRelativePath)
        ?? FilteredItems.FirstOrDefault();

    protected override async Task OnInitializedAsync()
    {
        _report = Workbench.LastReport;
        if (_report is not null)
        {
            SelectedRelativePath = _report.Result.Items.FirstOrDefault()?.RelativePath;
        }

        await RefreshRecentPathsAsync();
        await RefreshBaselinePreviewAsync();
        await RefreshHistoryAsync();
    }

    private async Task RunCompareAsync()
    {
        _errorMessage = null;
        _isRunning = true;

        try
        {
            _report = await Workbench.RunAsync(
                new GuardianRunRequest(
                    _runForm.CurrentRootPath,
                    _runForm.PatchRootPath,
                    _runForm.BaselinePath,
                    _runForm.OutputRootPath,
                    _runForm.ReportTitle));

            ApplyReport(_report);
            await RefreshRecentPathsAsync();
            await RefreshHistoryAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isRunning = false;
        }
    }

    private Task RerunAsync() => HasReport ? RunCompareAsync() : Task.CompletedTask;

    private async Task RefreshHistoryAsync()
    {
        if (string.IsNullOrWhiteSpace(_runForm.OutputRootPath))
        {
            _history = Array.Empty<ExecutionHistoryEntry>();
            return;
        }

        _history = await Workbench.ListRecentAsync(_runForm.OutputRootPath);
    }

    private async Task RefreshRecentPathsAsync()
    {
        var currentTask = Workbench.ListRecentPathsAsync(RecentPathKind.CurrentRoot);
        var patchTask = Workbench.ListRecentPathsAsync(RecentPathKind.PatchRoot);
        var baselineTask = Workbench.ListRecentPathsAsync(RecentPathKind.BaselineFile);
        var outputTask = Workbench.ListRecentPathsAsync(RecentPathKind.OutputRoot);

        await Task.WhenAll(currentTask, patchTask, baselineTask, outputTask);

        _recentCurrentRoots = currentTask.Result;
        _recentPatchRoots = patchTask.Result;
        _recentBaselinePaths = baselineTask.Result;
        _recentOutputRoots = outputTask.Result;
    }

    private async Task RefreshBaselinePreviewAsync()
    {
        _baselinePreview = null;
        _baselinePreviewError = null;

        if (string.IsNullOrWhiteSpace(_runForm.BaselinePath) || !File.Exists(_runForm.BaselinePath))
        {
            return;
        }

        try
        {
            _baselinePreview = await Workbench.PreviewBaselineAsync(_runForm.BaselinePath);
        }
        catch (Exception ex)
        {
            _baselinePreviewError = ex.Message;
        }
    }

    private async Task LoadHistoryAsync(string jsonResultPath)
    {
        var report = await Workbench.LoadAsync(jsonResultPath);
        if (report is null)
        {
            _errorMessage = "Failed to load the selected execution history entry.";
            return;
        }

        _errorMessage = null;
        ApplyReport(report);
    }

    private async Task OpenFileAsync(string? path)
    {
        if (string.IsNullOrWhiteSpace(path) || !File.Exists(path))
        {
            return;
        }

        await Launcher.Default.OpenAsync(new OpenFileRequest(Path.GetFileName(path), new ReadOnlyFile(path)));
    }

    private async Task BrowseBaselineAsync()
    {
        try
        {
            _errorMessage = null;
            var path = await PathSelector.PickBaselineFileAsync();
            await ApplyPathAsync(PathField.BaselinePath, path, rememberPath: true);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task BrowseFolderAsync(PathField field)
    {
        try
        {
            _errorMessage = null;
            var path = await PathSelector.PickFolderAsync("Select");
            await ApplyPathAsync(field, path, rememberPath: true);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private Task ApplyRecentPathAsync(PathField field, string? path)
        => ApplyPathAsync(field, path, rememberPath: false);

    private async Task ApplyPathAsync(PathField field, string? path, bool rememberPath)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return;
        }

        switch (field)
        {
            case PathField.CurrentRoot:
                _runForm.CurrentRootPath = path;
                break;
            case PathField.PatchRoot:
                _runForm.PatchRootPath = path;
                break;
            case PathField.BaselinePath:
                _runForm.BaselinePath = path;
                await RefreshBaselinePreviewAsync();
                break;
            case PathField.OutputRoot:
                _runForm.OutputRootPath = path;
                await RefreshHistoryAsync();
                break;
            default:
                throw new ArgumentOutOfRangeException(nameof(field), field, null);
        }

        if (rememberPath)
        {
            await Workbench.RememberPathAsync(MapRecentPathKind(field), path);
            await RefreshRecentPathsAsync();
        }
    }

    private Task OnBaselinePathChangedAsync()
        => RefreshBaselinePreviewAsync();

    private Task OnOutputRootChangedAsync()
        => RefreshHistoryAsync();

    private void SelectFilter(ResultFilter filter)
    {
        _selectedFilter = filter;
        SelectedRelativePath = FilteredItems.FirstOrDefault()?.RelativePath;
    }

    private void SelectItem(string relativePath)
        => SelectedRelativePath = relativePath;

    private void ApplyReport(ExecutionReport report)
    {
        _report = report;
        SelectedRelativePath = report.Result.Items
            .OrderByDescending(GetSeverityWeight)
            .ThenBy(item => item.RelativePath, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault()?.RelativePath;
    }

    private bool MatchesFilter(ComparisonItemResult item)
        => _selectedFilter switch
        {
            ResultFilter.All => true,
            ResultFilter.Changed => item.Status == CompareStatus.Changed,
            ResultFilter.MissingRequired => item.Status == CompareStatus.MissingRequired,
            ResultFilter.Error => item.Status == CompareStatus.Error,
            ResultFilter.Ok => item.Status == CompareStatus.Ok,
            _ => true,
        };

    private bool MatchesSearch(ComparisonItemResult item)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        var probe = string.Join(' ', item.RelativePath, item.RuleId, item.Status, item.Severity, item.FileType, item.Summary);
        return probe.Contains(_searchText, StringComparison.OrdinalIgnoreCase);
    }

    private string GetCount(string key)
        => !HasReport
            ? "0"
            : key == "Total"
                ? _report!.Summary.TotalFileCount.ToString()
                : _report!.Summary.StatusCounts.GetValueOrDefault(key, 0).ToString();

    private string GetCriticalCount()
    {
        if (!HasReport)
        {
            return "0";
        }

        var missingRequired = _report!.Summary.StatusCounts.GetValueOrDefault(CompareStatus.MissingRequired.ToString(), 0);
        var errors = _report.Summary.StatusCounts.GetValueOrDefault(CompareStatus.Error.ToString(), 0);
        return (missingRequired + errors).ToString();
    }

    private string GetFastestStageLabel()
    {
        var stage = PerformanceStages
            .Where(stage => stage.ItemCount > 0 && stage.ItemsPerSecond > 0)
            .OrderByDescending(stage => stage.ItemsPerSecond)
            .FirstOrDefault();

        return stage is null
            ? "-"
            : $"{stage.StageName} ({FormatThroughput(stage.ItemsPerSecond)})";
    }

    private static int GetSeverityWeight(ComparisonItemResult item)
        => item.Severity switch
        {
            Severity.Critical => 4,
            Severity.High => 3,
            Severity.Medium => 2,
            _ => 1,
        };

    private static string GetStatusBadgeClass(CompareStatus status)
        => status switch
        {
            CompareStatus.Ok => "bg-emerald-100 text-emerald-700 ring-1 ring-inset ring-emerald-200",
            CompareStatus.Changed => "bg-amber-100 text-amber-700 ring-1 ring-inset ring-amber-200",
            CompareStatus.Added => "bg-blue-100 text-blue-700 ring-1 ring-inset ring-blue-200",
            CompareStatus.Removed => "bg-slate-200 text-slate-700 ring-1 ring-inset ring-slate-300",
            CompareStatus.MissingRequired => "bg-red-100 text-red-700 ring-1 ring-inset ring-red-200",
            CompareStatus.Error => "bg-fuchsia-100 text-fuchsia-700 ring-1 ring-inset ring-fuchsia-200",
            _ => "bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200",
        };

    private static string GetSeverityBadgeClass(Severity severity)
        => severity switch
        {
            Severity.Critical => "bg-red-100 text-red-700 ring-1 ring-inset ring-red-200",
            Severity.High => "bg-amber-100 text-amber-700 ring-1 ring-inset ring-amber-200",
            Severity.Medium => "bg-blue-100 text-blue-700 ring-1 ring-inset ring-blue-200",
            _ => "bg-emerald-100 text-emerald-700 ring-1 ring-inset ring-emerald-200",
        };

    private static string FilterLabel(ResultFilter filter)
        => filter switch
        {
            ResultFilter.MissingRequired => "Missing Required",
            _ => filter.ToString(),
        };

    private static string FormatDuration(double durationMs)
        => durationMs >= 1000d
            ? $"{durationMs / 1000d:0.00} s"
            : $"{durationMs:0.##} ms";

    private static string FormatThroughput(double itemsPerSecond)
        => itemsPerSecond <= 0
            ? "-"
            : $"{itemsPerSecond:0.##} items/s";

    private static PathStatusBadge EvaluateDirectoryBadge(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return new("Enter path", "bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200");
        }

        if (Directory.Exists(path))
        {
            return new("Ready", "bg-emerald-100 text-emerald-700 ring-1 ring-inset ring-emerald-200");
        }

        if (File.Exists(path))
        {
            return new("Not folder", "bg-amber-100 text-amber-700 ring-1 ring-inset ring-amber-200");
        }

        return new("Missing", "bg-red-100 text-red-700 ring-1 ring-inset ring-red-200");
    }

    private static PathStatusBadge EvaluateBaselineBadge(string? path, string? previewError)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return new("Enter file", "bg-slate-100 text-slate-700 ring-1 ring-inset ring-slate-200");
        }

        if (!File.Exists(path))
        {
            return new("Missing", "bg-red-100 text-red-700 ring-1 ring-inset ring-red-200");
        }

        var extension = Path.GetExtension(path);
        if (!string.Equals(extension, ".xlsx", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(extension, ".xlsm", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(extension, ".xls", StringComparison.OrdinalIgnoreCase))
        {
            return new("Invalid type", "bg-amber-100 text-amber-700 ring-1 ring-inset ring-amber-200");
        }

        if (!string.IsNullOrWhiteSpace(previewError))
        {
            return new("Invalid", "bg-red-100 text-red-700 ring-1 ring-inset ring-red-200");
        }

        return new("Ready", "bg-emerald-100 text-emerald-700 ring-1 ring-inset ring-emerald-200");
    }

    private sealed record SummaryCard(string Title, string Value, string Badge, string BadgeClass, string Note);
    private sealed record PathStatusBadge(string Label, string BadgeClass);

    private sealed class RunFormModel
    {
        public RunFormModel()
        {
            ReportTitle = "Guardian Patch Inspection";
            OutputRootPath = Path.Combine(
                Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments),
                "NexusWorks.Guardian",
                "output");
        }

        [Required]
        public string ReportTitle { get; set; }

        [Required]
        public string CurrentRootPath { get; set; } = string.Empty;

        [Required]
        public string PatchRootPath { get; set; } = string.Empty;

        [Required]
        public string BaselinePath { get; set; } = string.Empty;

        [Required]
        public string OutputRootPath { get; set; }
    }

    private enum ResultFilter
    {
        All,
        Changed,
        MissingRequired,
        Error,
        Ok,
    }

    private enum PathField
    {
        CurrentRoot,
        PatchRoot,
        BaselinePath,
        OutputRoot,
    }

    private static RecentPathKind MapRecentPathKind(PathField field)
        => field switch
        {
            PathField.CurrentRoot => RecentPathKind.CurrentRoot,
            PathField.PatchRoot => RecentPathKind.PatchRoot,
            PathField.BaselinePath => RecentPathKind.BaselineFile,
            PathField.OutputRoot => RecentPathKind.OutputRoot,
            _ => throw new ArgumentOutOfRangeException(nameof(field), field, null),
        };
}
