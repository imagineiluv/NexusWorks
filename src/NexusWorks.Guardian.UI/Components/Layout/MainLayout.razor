@inherits LayoutComponentBase
@inject GuardianWorkbenchService Workbench

<div class="gw-shell">
    <header class="gw-toolbar">
        <div class="mx-auto flex w-full max-w-[1600px] flex-wrap items-center justify-between gap-4 px-4 py-4 lg:px-6">
            <div class="flex items-center gap-3">
                <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-blue-500/15 text-blue-300 ring-1 ring-inset ring-blue-400/30">
                    <span class="material-symbols-outlined text-[22px]">shield</span>
                </div>
                <div>
                    <div class="text-[11px] font-semibold uppercase tracking-[0.24em] text-blue-200/70">NexusWorks</div>
                    <h1 class="text-lg font-semibold tracking-[-0.03em]">Guardian</h1>
                </div>
            </div>

            <div class="flex w-full flex-wrap items-center justify-start gap-3 text-left md:w-auto md:justify-end md:text-right">
                <div class="rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-xs text-slate-300">
                    Tailwind Review Console
                </div>
                <div class="rounded-full border border-emerald-400/20 bg-emerald-500/10 px-3 py-1.5 text-xs text-emerald-200">
                    @(Workbench.LastReport is null
                        ? "Awaiting first run"
                        : $"Last run {Workbench.LastReport.Summary.CompletedAt.ToLocalTime():HH:mm:ss}")
                </div>
            </div>
        </div>
    </header>

    <main class="min-h-0 flex-1 overflow-y-auto overflow-x-hidden">
        <div class="mx-auto flex min-h-full w-full max-w-[1840px] flex-col px-4 py-4 lg:px-6 lg:py-6 2xl:px-8">
            @Body
        </div>
    </main>
</div>
